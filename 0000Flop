  TRY.
      cl_salv_table=>factory(
        IMPORTING r_salv_table = lo_salv
        CHANGING  t_table      = gt_output ).
    CATCH cx_salv_msg INTO lx_msg.
      MESSAGE lx_msg->get_text( ) TYPE 'E'.
      RETURN.
  ENDTRY.

  lo_funcs = lo_salv->get_functions( ).
  lo_funcs->set_all( abap_true ).

  lo_display = lo_salv->get_display_settings( ).
  lo_display->set_striped_pattern( abap_true ).
  lo_display->set_list_header( 'FLOP Report - Financial Listing of Profitability' ).

  lo_layout = lo_salv->get_layout( ).
  ls_layout_key-report = sy-repid.
  lo_layout->set_key( ls_layout_key ).
  lo_layout->set_save_restriction( if_salv_c_layout=>restrict_none ).

  lo_columns = lo_salv->get_columns( ).
  lo_columns->set_optimize( abap_true ).

  TRY.

      lo_column = lo_columns->get_column( 'HEAD' ).
      lo_column->set_short_text( 'Head' ).
      lo_column->set_medium_text( 'Head' ).
      lo_column->set_long_text( 'Head' ).

      lo_column = lo_columns->get_column( 'GROUPING' ).
      lo_column->set_short_text( 'Group' ).
      lo_column->set_medium_text( 'Grouping' ).
      lo_column->set_long_text( 'Grouping' ).

      lo_column = lo_columns->get_column( 'CY_AMOUNT' ).
      lo_column->set_short_text( 'CurrYr' ).
      lo_column->set_medium_text( 'Current Year' ).
      lo_column->set_long_text( 'Current Year Amount' ).

      lo_column = lo_columns->get_column( 'PY_AMOUNT' ).
      lo_column->set_short_text( 'PrevYr' ).
      lo_column->set_medium_text( 'Previous Year' ).
      lo_column->set_long_text( 'Previous Year Amount' ).

      lo_column = lo_columns->get_column( 'PERCENTAGE' ).
      lo_column->set_short_text( 'Fix%' ).
      lo_column->set_medium_text( 'Fixed %' ).
      lo_column->set_long_text( 'Fixed Percentage' ).

      lo_column = lo_columns->get_column( 'ADDBACK_CY' ).
      lo_column->set_short_text( 'AddBkCY' ).
      lo_column->set_medium_text( 'AddBack CY' ).
      lo_column->set_long_text( 'Add Back in Net Profit (CY)' ).

      lo_column = lo_columns->get_column( 'ADDBACK_PY' ).
      lo_column->set_short_text( 'AddBkPY' ).
      lo_column->set_medium_text( 'AddBack PY' ).
      lo_column->set_long_text( 'Add Back in Net Profit (PY)' ).

      lo_column = lo_columns->get_column( 'NET_PROFIT' ).
      lo_column->set_short_text( 'NetProf' ).
      lo_column->set_medium_text( 'Net Profit' ).
      lo_column->set_long_text( 'Net Profit + Year End (TBD)' ).

    CATCH cx_salv_not_found INTO lx_not_found.
      MESSAGE lx_not_found->get_text( ) TYPE 'S' DISPLAY LIKE 'W'.
  ENDTRY.

  lo_salv->display( ).

ENDFORM.
