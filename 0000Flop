### Include: ZFLOP_REPORT_F01

```abap
*&---------------------------------------------------------------------*
*& Include ZFLOP_REPORT_F01
*&---------------------------------------------------------------------*

*&---------------------------------------------------------------------*
*& Form SET_DEFAULTS
*&---------------------------------------------------------------------*
FORM set_defaults.
  p_date = sy-datum.
ENDFORM.

*&---------------------------------------------------------------------*
*& Form TOGGLE_DATE_FIELDS
*&---------------------------------------------------------------------*
FORM toggle_date_fields.

  LOOP AT SCREEN.
    CASE abap_true.
      WHEN rb_singl.
        IF screen-group1 = 'RN'.
          screen-active = 0.
          MODIFY SCREEN.
        ENDIF.
        IF screen-group1 = 'SI'.
          screen-active = 1.
          MODIFY SCREEN.
        ENDIF.
      WHEN rb_range.
        IF screen-group1 = 'SI'.
          screen-active = 0.
          MODIFY SCREEN.
        ENDIF.
        IF screen-group1 = 'RN'.
          screen-active = 1.
          MODIFY SCREEN.
        ENDIF.
    ENDCASE.
  ENDLOOP.

ENDFORM.

*&---------------------------------------------------------------------*
*& Form VALIDATE_INPUT
*&---------------------------------------------------------------------*
FORM validate_input.

  IF rb_singl = abap_true AND p_date IS INITIAL.
    MESSAGE 'Please enter a posting date' TYPE 'E'.
  ENDIF.

  IF rb_range = abap_true AND s_budat[] IS INITIAL.
    MESSAGE 'Please enter a date range' TYPE 'E'.
  ENDIF.

ENDFORM.

*&---------------------------------------------------------------------*
*& Form DETERMINE_DATE_RANGES
*&---------------------------------------------------------------------*
FORM determine_date_ranges.

  DATA: lv_year  TYPE numc4,
        lv_month TYPE numc2,
        lv_py_year TYPE numc4.

  IF rb_singl = abap_true.

    lv_year  = p_date+0(4).
    lv_month = p_date+4(2).

    IF lv_month >= 4.
      CONCATENATE lv_year '0401' INTO gv_cy_from.
      lv_py_year = lv_year + 1.
      CONCATENATE lv_py_year '0331' INTO gv_cy_to.
    ELSE.
      CONCATENATE lv_year '0331' INTO gv_cy_to.
      lv_py_year = lv_year - 1.
      CONCATENATE lv_py_year '0401' INTO gv_cy_from.
    ENDIF.

    gv_ref_date = p_date.

  ELSE.

    READ TABLE s_budat INDEX 1 INTO DATA(ls_budat).
    gv_cy_from = ls_budat-low.
    gv_cy_to   = ls_budat-high.
    IF gv_cy_to IS INITIAL.
      gv_cy_to = gv_cy_from.
    ENDIF.

    gv_ref_date = gv_cy_to.

  ENDIF.

  lv_year = gv_cy_from+0(4).
  lv_year = lv_year - 1.
  CONCATENATE lv_year gv_cy_from+4(4) INTO gv_py_from.

  lv_year = gv_cy_to+0(4).
  lv_year = lv_year - 1.
  CONCATENATE lv_year gv_cy_to+4(4) INTO gv_py_to.

ENDFORM.

*&---------------------------------------------------------------------*
*& Form FETCH_GL_MAPPING
*&---------------------------------------------------------------------*
FORM fetch_gl_mapping.

  DATA: ls_racct LIKE LINE OF gr_racct.

  SELECT gl
         gl_code_names
         head
         grouping
         percentage
         zdatum
         zzdatum
    FROM zfi_flopglmap
    INTO TABLE gt_glmap
    WHERE zdatum  <= gv_ref_date
      AND ( zzdatum >= gv_ref_date OR zzdatum = '00000000' ).

  SORT gt_glmap BY gl zdatum DESCENDING.
  DELETE ADJACENT DUPLICATES FROM gt_glmap COMPARING gl.
  SORT gt_glmap BY head grouping gl.

  CLEAR gr_racct[].
  ls_racct-sign   = 'I'.
  ls_racct-option = 'EQ'.

  LOOP AT gt_glmap INTO DATA(ls_glmap).
    ls_racct-low = ls_glmap-gl.
    APPEND ls_racct TO gr_racct.
  ENDLOOP.

ENDFORM.

*&---------------------------------------------------------------------*
*& Form FETCH_FAGLFLEXA_DATA
*&---------------------------------------------------------------------*
FORM fetch_faglflexa_data.

  CHECK gt_glmap[] IS NOT INITIAL.
  CHECK gr_racct[] IS NOT INITIAL.

  SELECT racct
         SUM( hsl ) AS hsl
    FROM faglflexa
    INTO TABLE gt_flexa_cy
    WHERE rldnr  = gc_rldnr
      AND rbukrs IN s_bukrs
      AND racct  IN gr_racct
      AND budat  BETWEEN gv_cy_from AND gv_cy_to
    GROUP BY racct.

  SELECT racct
         SUM( hsl ) AS hsl
    FROM faglflexa
    INTO TABLE gt_flexa_py
    WHERE rldnr  = gc_rldnr
      AND rbukrs IN s_bukrs
      AND racct  IN gr_racct
      AND budat  BETWEEN gv_py_from AND gv_py_to
    GROUP BY racct.

  SORT gt_flexa_cy BY racct.
  SORT gt_flexa_py BY racct.

ENDFORM.

*&---------------------------------------------------------------------*
*& Form BUILD_OUTPUT
*&---------------------------------------------------------------------*
FORM build_output.

  DATA: ls_output TYPE ty_output,
        lv_cy     TYPE faglflexa-hsl,
        lv_py     TYPE faglflexa-hsl.

  FIELD-SYMBOLS: <ls_cy>  TYPE ty_flexa,
                 <ls_py>  TYPE ty_flexa,
                 <ls_out> TYPE ty_output.

  DATA: lt_grp_done TYPE SORTED TABLE OF ty_grp_key
          WITH UNIQUE KEY head grouping.

  DATA: ls_grp_key TYPE ty_grp_key.

  CLEAR gt_output[].

  LOOP AT gt_glmap INTO DATA(ls_glmap).

    CLEAR: lv_cy, lv_py.

    READ TABLE gt_flexa_cy ASSIGNING <ls_cy>
      WITH KEY racct = ls_glmap-gl BINARY SEARCH.
    IF sy-subrc = 0.
      lv_cy = <ls_cy>-hsl.
    ENDIF.

    READ TABLE gt_flexa_py ASSIGNING <ls_py>
      WITH KEY racct = ls_glmap-gl BINARY SEARCH.
    IF sy-subrc = 0.
      lv_py = <ls_py>-hsl.
    ENDIF.

    ls_grp_key-head     = ls_glmap-head.
    ls_grp_key-grouping = ls_glmap-grouping.

    READ TABLE lt_grp_done
      WITH KEY head     = ls_glmap-head
               grouping = ls_glmap-grouping
      TRANSPORTING NO FIELDS.

    IF sy-subrc = 0.

      READ TABLE gt_output ASSIGNING <ls_out>
        WITH KEY head     = ls_glmap-head
                 grouping = ls_glmap-grouping.
      IF sy-subrc = 0.
        <ls_out>-cy_amount = <ls_out>-cy_amount + lv_cy.
        <ls_out>-py_amount = <ls_out>-py_amount + lv_py.
      ENDIF.

    ELSE.

      INSERT ls_grp_key INTO TABLE lt_grp_done.

      CLEAR ls_output.
      ls_output-head       = ls_glmap-head.
      ls_output-grouping   = ls_glmap-grouping.
      ls_output-percentage = ls_glmap-percentage.
      ls_output-cy_amount  = lv_cy.
      ls_output-py_amount  = lv_py.
      APPEND ls_output TO gt_output.

    ENDIF.

  ENDLOOP.

  LOOP AT gt_output ASSIGNING <ls_out>.
    <ls_out>-addback_cy = <ls_out>-cy_amount * <ls_out>-percentage / 100.
    <ls_out>-addback_py = <ls_out>-py_amount * <ls_out>-percentage / 100.
  ENDLOOP.

  SORT gt_output BY head grouping.

ENDFORM.

*&---------------------------------------------------------------------*
*& Form DISPLAY_ALV
*&---------------------------------------------------------------------*
FORM display_alv.

  DATA: lo_salv       TYPE REF TO cl_salv_table,
        lo_columns    TYPE REF TO cl_salv_columns_table,
        lo_column     TYPE REF TO cl_salv_column,
        lo_funcs      TYPE REF TO cl_salv_functions_list,
        lo_display    TYPE REF TO cl_salv_display_settings,
        lo_layout     TYPE REF TO cl_salv_layout,
        ls_layout_key TYPE salv_s_layout_key,
        lx_msg        TYPE REF TO cx_salv_msg,
