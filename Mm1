*----------------------------------------------------------------------*
* CHANGE 1: Replace FORM convert_week_to_dates with this version
*----------------------------------------------------------------------*

FORM convert_week_to_dates.

  DATA: lv_week_input TYPE scal-week.

  IF rb_week = abap_true.
    " Mode 1: Week + Year → convert to date range
    lv_week_input = p_year && p_week.
    gv_week = lv_week_input.

    CALL FUNCTION 'WEEK_GET_FIRST_DAY'
      EXPORTING
        week         = lv_week_input
      IMPORTING
        date         = gv_date_from
      EXCEPTIONS
        week_invalid = 1
        OTHERS       = 2.

    IF sy-subrc <> 0.
      MESSAGE 'Invalid week/year combination. Please check.' TYPE 'E'.
    ENDIF.

    gv_date_to = gv_date_from + 6.

  ELSEIF rb_date = abap_true.
    " Mode 2: Date Range → use directly
    gv_date_from = p_dtfrom.
    gv_date_to   = p_dtto.

    " Also derive week number for ALV display
    CALL FUNCTION 'DATE_GET_WEEK'
      EXPORTING
        date         = gv_date_from
      IMPORTING
        week         = gv_week
      EXCEPTIONS
        date_invalid = 1
        OTHERS       = 2.

    IF sy-subrc <> 0.
      gv_week = '000000'.  "Fallback if date invalid
    ENDIF.

  ENDIF.

ENDFORM.

*----------------------------------------------------------------------*
* CHANGE 2: Add this NEW form - call it after build_output
*           Add "PERFORM filter_by_category." in process_report
*           AFTER "PERFORM build_output." and BEFORE "PERFORM display_alv."
*----------------------------------------------------------------------*

FORM filter_by_category.

  " If user selected PB only → remove Non-PB and Unknown
  IF rb_pb = abap_true.
    DELETE gt_output WHERE category <> gc_pb.
  ENDIF.

  " If user selected Non-PB only → remove PB and Unknown
  IF rb_npb = abap_true.
    DELETE gt_output WHERE category <> gc_npb.
  ENDIF.

  " If rb_all is selected → no filtering, show everything (default)

  IF gt_output IS INITIAL.
    MESSAGE 'No records found for the selected category filter'
            TYPE 'S' DISPLAY LIKE 'E'.
    LEAVE LIST-PROCESSING.
  ENDIF.

ENDFORM.

*----------------------------------------------------------------------*
* CHANGE 3: Update FORM process_report - add filter_by_category
*----------------------------------------------------------------------*

FORM process_report.

  PERFORM convert_week_to_dates.
  PERFORM fetch_grn_data.
  PERFORM check_cancelled_documents.
  PERFORM validate_po_document_type.
  PERFORM fetch_po_item_details.
  PERFORM fetch_material_master_data.
  PERFORM fetch_vendor_data.
  PERFORM fetch_cn_code_master.
  PERFORM build_output.
  PERFORM filter_by_category.            "<-- NEW: added here
  PERFORM display_alv.

ENDFORM.

