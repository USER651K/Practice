*&---------------------------------------------------------------------*
*& Report ZMM_RVOREP
*&---------------------------------------------------------------------*
REPORT zmm_rvorep.

INCLUDE zmm_rvorep_top.
INCLUDE zmm_rvorep_sel.
INCLUDE zmm_rvorep_f01.

INITIALIZATION.
  p_year = sy-datum+0(4).

*----------------------------------------------------------------------*
* AT SELECTION-SCREEN OUTPUT - Toggle field visibility
*----------------------------------------------------------------------*
AT SELECTION-SCREEN OUTPUT.

  LOOP AT SCREEN.
    " When Week mode selected → show Week/Year, hide Date Range
    IF rb_week = abap_true.
      IF screen-group1 = 'DTR'.
        screen-active = 0.
        MODIFY SCREEN.
      ENDIF.
    ENDIF.

    " When Date mode selected → show Date Range, hide Week/Year
    IF rb_date = abap_true.
      IF screen-group1 = 'WKY'.
        screen-active = 0.
        MODIFY SCREEN.
      ENDIF.
    ENDIF.
  ENDLOOP.

*----------------------------------------------------------------------*
* AT SELECTION-SCREEN - Validation
*----------------------------------------------------------------------*
AT SELECTION-SCREEN.

  " Validate Week mode inputs
  IF rb_week = abap_true.
    IF p_week IS INITIAL OR p_year IS INITIAL.
      MESSAGE 'Please enter both Week Number and Year' TYPE 'E'.
    ENDIF.
    IF p_week < '01' OR p_week > '53'.
      MESSAGE 'Week number must be between 01 and 53' TYPE 'E'.
    ENDIF.
  ENDIF.

  " Validate Date mode inputs
  IF rb_date = abap_true.
    IF p_dtfrom IS INITIAL OR p_dtto IS INITIAL.
      MESSAGE 'Please enter both From and To dates' TYPE 'E'.
    ENDIF.
    IF p_dtfrom > p_dtto.
      MESSAGE 'From date cannot be greater than To date' TYPE 'E'.
    ENDIF.
  ENDIF.

START-OF-SELECTION.

  PERFORM process_report.





*&---------------------------------------------------------------------*
*& Include ZMM_RVOREP_SEL
*&---------------------------------------------------------------------*

*----------------------------------------------------------------------*
* Block 1: Input Mode (Radio Buttons)
*----------------------------------------------------------------------*
SELECTION-SCREEN BEGIN OF BLOCK b1 WITH FRAME TITLE TEXT-001.

  PARAMETERS: rb_week RADIOBUTTON GROUP rb1 DEFAULT 'X' USER-COMMAND uc1,
              rb_date RADIOBUTTON GROUP rb1.

SELECTION-SCREEN END OF BLOCK b1.

*----------------------------------------------------------------------*
* Block 2: Week + Year (MODIF ID WKY → toggled by radio button)
*----------------------------------------------------------------------*
SELECTION-SCREEN BEGIN OF BLOCK b2 WITH FRAME TITLE TEXT-002.

  PARAMETERS: p_week TYPE n LENGTH 2   MODIF ID wky,
              p_year TYPE gjahr        MODIF ID wky.

SELECTION-SCREEN END OF BLOCK b2.

*----------------------------------------------------------------------*
* Block 3: Date Range (MODIF ID DTR → toggled by radio button)
*----------------------------------------------------------------------*
SELECTION-SCREEN BEGIN OF BLOCK b3 WITH FRAME TITLE TEXT-003.

  PARAMETERS: p_dtfrom TYPE sy-datum   MODIF ID dtr,
              p_dtto   TYPE sy-datum   MODIF ID dtr.

SELECTION-SCREEN END OF BLOCK b3.

*----------------------------------------------------------------------*
* Block 4: Category Filter (Radio Buttons)
*----------------------------------------------------------------------*
SELECTION-SCREEN BEGIN OF BLOCK b4 WITH FRAME TITLE TEXT-004.

  PARAMETERS: rb_all RADIOBUTTON GROUP rb2 DEFAULT 'X',
              rb_pb  RADIOBUTTON GROUP rb2,
              rb_npb RADIOBUTTON GROUP rb2.

SELECTION-SCREEN END OF BLOCK b4.

*----------------------------------------------------------------------*
* Text Elements to maintain in SE38:
*   TEXT-001 = 'Input Mode'
*   TEXT-002 = 'Week & Year'
*   TEXT-003 = 'Date Range'
*   TEXT-004 = 'Category Filter'
*
* Selection Texts:
*   RB_WEEK  = 'By Week & Year'
*   RB_DATE  = 'By Date Range'
*   P_WEEK   = 'Week Number'
*   P_YEAR   = 'Year'
*   P_DTFROM = 'Date From'
*   P_DTTO   = 'Date To'
*   RB_ALL   = 'All (PB + Non-PB)'
*   RB_PB    = 'Parboiled Only'
*   RB_NPB   = 'Non-Parboiled Only'
*----------------------------------------------------------------------*





