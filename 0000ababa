REPORT zpp_bom_pv_report.

TABLES: mara, t001w.

TYPES:
  BEGIN OF ty_mkal,
    mandt TYPE mkal-mandt,
    matnr TYPE mkal-matnr,
    werks TYPE mkal-werks,
    verid TYPE mkal-verid,
    plnty TYPE mkal-plnty,
    stlan TYPE mkal-stlan,
    plnnr TYPE mkal-plnnr,
    stlal TYPE mkal-stlal,
    bstmi TYPE mkal-bstmi,
    alnal TYPE mkal-alnal,
    bstma TYPE mkal-bstma,
    adatu TYPE mkal-adatu,
    bdatu TYPE mkal-bdatu,
  END OF ty_mkal,

  BEGIN OF ty_mast,
    matnr TYPE mast-matnr,
    werks TYPE mast-werks,
    stlan TYPE mast-stlan,
    stlal TYPE mast-stlal,
    stlnr TYPE mast-stlnr,
  END OF ty_mast,

  BEGIN OF ty_makt,
    matnr TYPE makt-matnr,
    spras TYPE makt-spras,
    maktx TYPE makt-maktx,
  END OF ty_makt,

  BEGIN OF ty_alv,
    werks TYPE mkal-werks,
    matnr TYPE mkal-matnr,
    maktx TYPE makt-maktx,
    verid TYPE mkal-verid,
    adatu TYPE mkal-adatu,
    bdatu TYPE mkal-bdatu,
    bstmi TYPE mkal-bstmi,
    bstma TYPE mkal-bstma,
    stlnr TYPE mast-stlnr,
    stlal TYPE mkal-stlal,
    stlan TYPE mkal-stlan,
    plnty TYPE mkal-plnty,
    plnnr TYPE mkal-plnnr,
    alnal TYPE mkal-alnal,
  END OF ty_alv.

DATA: gt_mkal TYPE STANDARD TABLE OF ty_mkal,
      gt_mast TYPE STANDARD TABLE OF ty_mast,
      gt_makt TYPE STANDARD TABLE OF ty_makt,
      gt_alv  TYPE STANDARD TABLE OF ty_alv,
      gs_mkal TYPE ty_mkal,
      gs_mast TYPE ty_mast,
      gs_makt TYPE ty_makt,
      gs_alv  TYPE ty_alv.

DATA: gv_line      TYPE string,
      gv_records   TYPE i,
      gv_mtart     TYPE mara-mtart,
      gv_matnr_ext TYPE matnr.

DATA: gv_filepath    TYPE string,
      gv_timestamp   TYPE timestampl.

DATA: go_alv     TYPE REF TO cl_salv_table,
      go_funcs   TYPE REF TO cl_salv_functions_list,
      go_columns TYPE REF TO cl_salv_columns_table,
      go_column  TYPE REF TO cl_salv_column,
      go_display TYPE REF TO cl_salv_display_settings,
      go_layout  TYPE REF TO cl_salv_layout,
      gs_lkey    TYPE salv_s_layout_key.

SELECTION-SCREEN BEGIN OF BLOCK b1 WITH FRAME TITLE TEXT-001.
  SELECT-OPTIONS: s_matnr FOR mara-matnr MATCHCODE OBJECT mat1,
                  s_werks FOR t001w-werks OBLIGATORY.
SELECTION-SCREEN END OF BLOCK b1.

INITIALIZATION.
  GET PARAMETER ID 'MAT' FIELD s_matnr-low.
  GET PARAMETER ID 'WRK' FIELD s_werks-low.

AT SELECTION-SCREEN.

  IF s_matnr-low IS NOT INITIAL AND s_matnr-high IS INITIAL.
    SELECT SINGLE matnr mtart
      FROM mara
      INTO (mara-matnr, gv_mtart)
     WHERE matnr = s_matnr-low.
    IF sy-subrc <> 0.
      CALL FUNCTION 'CONVERSION_EXIT_MATN1_OUTPUT'
        EXPORTING input  = s_matnr-low
        IMPORTING output = gv_matnr_ext.
      MESSAGE |The material { gv_matnr_ext } does not exist or is not activated| TYPE 'E'.
    ENDIF.
  ENDIF.

  IF s_werks-low IS NOT INITIAL AND s_werks-high IS INITIAL.
    SELECT SINGLE werks
      FROM t001w
      INTO t001w-werks
     WHERE werks = s_werks-low.
    IF sy-subrc <> 0.
      MESSAGE |Plant { s_werks-low } does not exist| TYPE 'E'.
    ENDIF.
  ENDIF.

START-OF-SELECTION.

  PERFORM extract_data.

  IF gt_alv IS NOT INITIAL.
    PERFORM write_to_server.
    PERFORM display_alv.
  ELSE.
    MESSAGE 'No Data Found' TYPE 'S' DISPLAY LIKE 'E'.
  ENDIF.


FORM extract_data.

  SELECT mandt matnr werks verid plnty stlan plnnr stlal
         bstmi alnal bstma adatu bdatu
    FROM mkal
    INTO TABLE gt_mkal
   WHERE matnr IN s_matnr
     AND werks IN s_werks.

  IF gt_mkal IS INITIAL.
    RETURN.
  ENDIF.

  SELECT matnr werks stlan stlal stlnr
    FROM mast
    INTO TABLE gt_mast
     FOR ALL ENTRIES IN gt_mkal
   WHERE matnr = gt_mkal-matnr
     AND werks = gt_mkal-werks
     AND stlan = gt_mkal-stlan
     AND stlal = gt_mkal-stlal.

  SORT gt_mast BY matnr werks stlan stlal.

  SELECT matnr spras maktx
    FROM makt
    INTO TABLE gt_makt
     FOR ALL ENTRIES IN gt_mkal
   WHERE matnr = gt_mkal-matnr
     AND spras = 'EN'.

  SORT gt_makt BY matnr.

  LOOP AT gt_mkal INTO gs_mkal.
    CLEAR gs_alv.

    gs_alv-werks = gs_mkal-werks.
    gs_alv-matnr = gs_mkal-matnr.
    gs_alv-verid = gs_mkal-verid.
    gs_alv-adatu = gs_mkal-adatu.
    gs_alv-bdatu = gs_mkal-bdatu.
    gs_alv-bstmi = gs_mkal-bstmi.
    gs_alv-bstma = gs_mkal-bstma.
    gs_alv-stlal = gs_mkal-stlal.
    gs_alv-stlan = gs_mkal-stlan.
    gs_alv-plnty = gs_mkal-plnty.
    gs_alv-plnnr = gs_mkal-plnnr.
    gs_alv-alnal = gs_mkal-alnal.

    READ TABLE gt_makt INTO gs_makt
         WITH KEY matnr = gs_mkal-matnr
         BINARY SEARCH.
    IF sy-subrc = 0.
      gs_alv-maktx = gs_makt-maktx.
    ENDIF.

    READ TABLE gt_mast INTO gs_mast
         WITH KEY matnr = gs_mkal-matnr
                  werks = gs_mkal-werks
                  stlan = gs_mkal-stlan
                  stlal = gs_mkal-stlal
         BINARY SEARCH.
    IF sy-subrc = 0.
      gs_alv-stlnr = gs_mast-stlnr.
    ENDIF.

    APPEND gs_alv TO gt_alv.
  ENDLOOP.

  gv_records = lines( gt_alv ).

ENDFORM.


FORM write_to_server.

  DATA: lv_plnty TYPE string,
        lv_matnr TYPE string,
        lv_werks TYPE string,
        lv_verid TYPE string,
        lv_stlan TYPE string,
        lv_plnnr TYPE string,
        lv_stlal TYPE string,
        lv_bstmi TYPE string,
        lv_alnal TYPE string,
        lv_mandt TYPE string,
        lv_bstma TYPE string,
        lv_adatu TYPE string,
        lv_bdatu TYPE string,
        lv_stlnr TYPE string,
        lv_temp  TYPE c LENGTH 24.

  gv_filepath = '/mnt/edifiles/In_MKAL_MAST.csv'.

  GET TIME STAMP FIELD gv_timestamp.
  REPLACE '.csv' IN gv_filepath WITH |_{ gv_timestamp }.csv|.

  OPEN DATASET gv_filepath FOR OUTPUT IN TEXT MODE ENCODING DEFAULT.
  IF sy-subrc NE 0.
    MESSAGE 'Error opening file' TYPE 'E'.
    RETURN.
  ENDIF.

  CONCATENATE
    'TaskListType'
    'Item'
    'Site'
    'VersionID'
    'BOMUsage'
    'Group'
    'AlternativeBOM'
    'MinimumLotSizeQuantity'
    'GroupCounter'
    'SourceId'
    'MaximumLotSizeQuantity'
    'ValidFromDate'
    'ValidToDate'
    'BillofMaterial'
    INTO gv_line SEPARATED BY '|'.
  TRANSFER gv_line TO gv_filepath.

  LOOP AT gt_mkal INTO gs_mkal.

    CLEAR gv_line.

    lv_plnty = gs_mkal-plnty.
    CONDENSE lv_plnty NO-GAPS.

    CALL FUNCTION 'CONVERSION_EXIT_MATN1_OUTPUT'
      EXPORTING input  = gs_mkal-matnr
      IMPORTING output = lv_matnr.
    CONDENSE lv_matnr NO-GAPS.

    lv_werks = gs_mkal-werks.
    CONDENSE lv_werks NO-GAPS.

    lv_verid = gs_mkal-verid.
    CONDENSE lv_verid NO-GAPS.

    lv_stlan = gs_mkal-stlan.
    CONDENSE lv_stlan NO-GAPS.

    CALL FUNCTION 'CONVERSION_EXIT_ALPHA_OUTPUT'
      EXPORTING input  = gs_mkal-plnnr
      IMPORTING output = lv_plnnr.
    CONDENSE lv_plnnr NO-GAPS.

    lv_stlal = gs_mkal-stlal.
    CONDENSE lv_stlal NO-GAPS.

    WRITE gs_mkal-bstmi TO lv_temp LEFT-JUSTIFIED NO-GROUPING NO-SIGN DECIMALS 2.
    lv_bstmi = lv_temp.
    CONDENSE lv_bstmi NO-GAPS.

    WRITE gs_mkal-alnal TO lv_temp LEFT-JUSTIFIED NO-GROUPING NO-SIGN.
    lv_alnal = lv_temp.
    CONDENSE lv_alnal NO-GAPS.

    lv_mandt = gs_mkal-mandt.
    CONDENSE lv_mandt NO-GAPS.

    WRITE gs_mkal-bstma TO lv_temp LEFT-JUSTIFIED NO-GROUPING NO-SIGN DECIMALS 2.
    lv_bstma = lv_temp.
    CONDENSE lv_bstma NO-GAPS.

    PERFORM format_date USING gs_mkal-adatu CHANGING lv_adatu.
    PERFORM format_date USING gs_mkal-bdatu CHANGING lv_bdatu.

    READ TABLE gt_mast INTO gs_mast
         WITH KEY matnr = gs_mkal-matnr
                  werks = gs_mkal-werks
                  stlan = gs_mkal-stlan
                  stlal = gs_mkal-stlal
         BINARY SEARCH.
    IF sy-subrc = 0.
      CALL FUNCTION 'CONVERSION_EXIT_ALPHA_OUTPUT'
        EXPORTING input  = gs_mast-stlnr
        IMPORTING output = lv_stlnr.
    ELSE.
      CLEAR lv_stlnr.
    ENDIF.
    CONDENSE lv_stlnr NO-GAPS.

    CONCATENATE
      lv_plnty lv_matnr lv_werks lv_verid lv_stlan
      lv_plnnr lv_stlal lv_bstmi lv_alnal lv_mandt
      lv_bstma lv_adatu lv_bdatu lv_stlnr
      INTO gv_line SEPARATED BY '|'.
    TRANSFER gv_line TO gv_filepath.

  ENDLOOP.

  CLOSE DATASET gv_filepath.

  MESSAGE |File generated successfully: { gv_filepath }| TYPE 'S'.

ENDFORM.


FORM format_date USING    iv_date TYPE d
                 CHANGING ev_str  TYPE string.
  CLEAR ev_str.
  IF iv_date IS NOT INITIAL AND iv_date <> '00000000'.
    CONCATENATE iv_date+6(2) '.' iv_date+4(2) '.' iv_date+0(4) INTO ev_str.
  ENDIF.
ENDFORM.


FORM display_alv.

  DATA: lv_msg TYPE REF TO cx_salv_msg,
        lv_nf  TYPE REF TO cx_salv_not_found.

  TRY.
      cl_salv_table=>factory(
        IMPORTING r_salv_table = go_alv
        CHANGING  t_table      = gt_alv ).

      go_funcs = go_alv->get_functions( ).
      go_funcs->set_all( abap_true ).

      go_display = go_alv->get_display_settings( ).
      go_display->set_list_header(
        'RPSG Solvanta - Solar Module Daily Production Report - ALV Output' ).
      go_display->set_striped_pattern( abap_true ).

      go_layout = go_alv->get_layout( ).
      gs_lkey-report = sy-repid.
      go_layout->set_key( gs_lkey ).
      go_layout->set_save_restriction( if_salv_c_layout=>restrict_none ).

      go_columns = go_alv->get_columns( ).
      go_columns->set_optimize( abap_true ).

      TRY.
          go_column = go_columns->get_column( 'WERKS' ).
          go_column->set_short_text( 'Plant' ).
          go_column->set_medium_text( 'Plant' ).
          go_column->set_long_text( 'Plant' ).

          go_column = go_columns->get_column( 'MATNR' ).
          go_column->set_short_text( 'Material' ).
          go_column->set_medium_text( 'Material' ).
          go_column->set_long_text( 'Material' ).

          go_column = go_columns->get_column( 'MAKTX' ).
          go_column->set_short_text( 'Mat Desc' ).
          go_column->set_medium_text( 'Material Desc' ).
          go_column->set_long_text( 'Material Description' ).

          go_column = go_columns->get_column( 'VERID' ).
          go_column->set_short_text( 'ProdVer' ).
          go_column->set_medium_text( 'Production Ver' ).
          go_column->set_long_text( 'Production Version' ).

          go_column = go_columns->get_column( 'ADATU' ).
          go_column->set_short_text( 'ValidFrom' ).
          go_column->set_medium_text( 'Valid From Date' ).
          go_column->set_long_text( 'Valid From Date' ).

          go_column = go_columns->get_column( 'BDATU' ).
          go_column->set_short_text( 'ValidTo' ).
          go_column->set_medium_text( 'Valid To Date' ).
          go_column->set_long_text( 'Valid To Date' ).

          go_column = go_columns->get_column( 'BSTMI' ).
          go_column->set_short_text( 'From Lot' ).
          go_column->set_medium_text( 'From Lot Size' ).
          go_column->set_long_text( 'From Lot Size' ).

          go_column = go_columns->get_column( 'BSTMA' ).
          go_column->set_short_text( 'To Lot' ).
          go_column->set_medium_text( 'To Lot Size' ).
          go_column->set_long_text( 'To Lot Size' ).

          go_column = go_columns->get_column( 'STLNR' ).
          go_column->set_short_text( 'BOM' ).
          go_column->set_medium_text( 'BOM' ).
          go_column->set_long_text( 'BOM' ).

          go_column = go_columns->get_column( 'STLAL' ).
          go_column->set_short_text( 'BOM Alt' ).
          go_column->set_medium_text( 'BOM Alternative' ).
          go_column->set_long_text( 'BOM Alternative' ).

          go_column = go_columns->get_column( 'STLAN' ).
          go_column->set_short_text( 'BOM Usage' ).
          go_column->set_medium_text( 'BOM Usage' ).
          go_column->set_long_text( 'BOM Usage' ).

          go_column = go_columns->get_column( 'PLNTY' ).
          go_column->set_short_text( 'TskLstTyp' ).
          go_column->set_medium_text( 'Task List Type' ).
          go_column->set_long_text( 'Task List Type' ).

          go_column = go_columns->get_column( 'PLNNR' ).
          go_column->set_short_text( 'RtgGroup' ).
          go_column->set_medium_text( 'Routing Group' ).
          go_column->set_long_text( 'Routing Group' ).

          go_column = go_columns->get_column( 'ALNAL' ).
          go_column->set_short_text( 'RtgGrpCtr' ).
          go_column->set_medium_text( 'Rtg Grp Counter' ).
          go_column->set_long_text( 'Routing Group Counter' ).

        CATCH cx_salv_not_found INTO lv_nf.
      ENDTRY.

      go_alv->display( ).

    CATCH cx_salv_msg INTO lv_msg.
      MESSAGE lv_msg TYPE 'E'.
  ENDTRY.

ENDFORM.
