            e_menge  = lv_out_menge
          EXCEPTIONS
            error_in_application = 1
            error                = 2
            OTHERS               = 3.
        IF sy-subrc = 0.
          gs_alv-qty_mt = lv_out_menge.
        ENDIF.
      ENDIF.
    ENDIF.
