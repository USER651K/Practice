    lv_verid = gs_alv-verid. CONDENSE lv_verid NO-GAPS.
    lv_alnal = gs_alv-alnal. CONDENSE lv_alnal NO-GAPS.
    lv_matnr = gs_alv-matnr. CONDENSE lv_matnr NO-GAPS.
    lv_werks = gs_alv-werks. CONDENSE lv_werks NO-GAPS.
    lv_arbpl = gs_alv-arbpl. CONDENSE lv_arbpl NO-GAPS.
    lv_ktext = gs_alv-ktext. CONDENSE lv_ktext NO-GAPS.
    lv_vagrp = gs_alv-vagrp. CONDENSE lv_vagrp NO-GAPS.

    lv_lar01 = gs_alv-lar01. CONDENSE lv_lar01 NO-GAPS.
    lv_vge01 = gs_alv-vge01. CONDENSE lv_vge01 NO-GAPS.
    WRITE gs_alv-vgw01 TO lv_temp LEFT-JUSTIFIED NO-GROUPING NO-SIGN DECIMALS 3.
    lv_vgw01 = lv_temp. CONDENSE lv_vgw01 NO-GAPS.

    lv_lar02 = gs_alv-lar02. CONDENSE lv_lar02 NO-GAPS.
    lv_vge02 = gs_alv-vge02. CONDENSE lv_vge02 NO-GAPS.
    WRITE gs_alv-vgw02 TO lv_temp LEFT-JUSTIFIED NO-GROUPING NO-SIGN DECIMALS 3.
    lv_vgw02 = lv_temp. CONDENSE lv_vgw02 NO-GAPS.

    lv_lar03 = gs_alv-lar03. CONDENSE lv_lar03 NO-GAPS.
    lv_vge03 = gs_alv-vge03. CONDENSE lv_vge03 NO-GAPS.
    WRITE gs_alv-vgw03 TO lv_temp LEFT-JUSTIFIED NO-GROUPING NO-SIGN DECIMALS 3.
    lv_vgw03 = lv_temp. CONDENSE lv_vgw03 NO-GAPS.

    lv_lar04 = gs_alv-lar04. CONDENSE lv_lar04 NO-GAPS.
    lv_vge04 = gs_alv-vge04. CONDENSE lv_vge04 NO-GAPS.
    WRITE gs_alv-vgw04 TO lv_temp LEFT-JUSTIFIED NO-GROUPING NO-SIGN DECIMALS 3.
    lv_vgw04 = lv_temp. CONDENSE lv_vgw04 NO-GAPS.

    lv_lar05 = gs_alv-lar05. CONDENSE lv_lar05 NO-GAPS.
    lv_vge05 = gs_alv-vge05. CONDENSE lv_vge05 NO-GAPS.
    WRITE gs_alv-vgw05 TO lv_temp LEFT-JUSTIFIED NO-GROUPING NO-SIGN DECIMALS 3.
    lv_vgw05 = lv_temp. CONDENSE lv_vgw05 NO-GAPS.

    lv_lar06 = gs_alv-lar06. CONDENSE lv_lar06 NO-GAPS.
    lv_vge06 = gs_alv-vge06. CONDENSE lv_vge06 NO-GAPS.
    WRITE gs_alv-vgw06 TO lv_temp LEFT-JUSTIFIED NO-GROUPING NO-SIGN DECIMALS 3.
    lv_vgw06 = lv_temp. CONDENSE lv_vgw06 NO-GAPS.

    lv_plnme = gs_alv-plnme. CONDENSE lv_plnme NO-GAPS.

    WRITE gs_alv-losvn TO lv_temp LEFT-JUSTIFIED NO-GROUPING NO-SIGN DECIMALS 3.
    lv_losvn = lv_temp. CONDENSE lv_losvn NO-GAPS.

    CONCATENATE
      lv_plnnr lv_plnty '' lv_datuv lv_valid_to
      lv_bmsch lv_bmsch_mt lv_statu lv_verwe lv_verid
      lv_alnal lv_matnr lv_werks lv_arbpl lv_ktext
      lv_vagrp
