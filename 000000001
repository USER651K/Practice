FORM extract_data.

  DATA: lv_bmsch_mt TYPE menge_d,
        lv_arbid    TYPE plpo-arbid,
        lv_plko_ok  TYPE abap_bool,
        lv_makt_ok  TYPE abap_bool.

  SELECT matnr werks verid plnty plnnr alnal
    FROM mkal
    INTO TABLE gt_mkal
   WHERE matnr IN s_matnr
     AND werks IN s_werks.

  IF gt_mkal IS INITIAL.
    RETURN.
  ENDIF.

  SORT gt_mkal BY plnty plnnr alnal.

  SELECT plnty plnnr plnal datuv verwe statu plnme losvn vagrp valid_to
    FROM plko
    INTO TABLE gt_plko
     FOR ALL ENTRIES IN gt_mkal
   WHERE plnty = gt_mkal-plnty
     AND plnnr = gt_mkal-plnnr
     AND plnal = gt_mkal-alnal.

  IF gt_plko IS NOT INITIAL.
    SORT gt_plko BY plnty plnnr plnal.
  ENDIF.

  SELECT plnty plnnr plnal plnkn
    FROM plas
    INTO TABLE gt_plas
     FOR ALL ENTRIES IN gt_mkal
   WHERE plnty = gt_mkal-plnty
     AND plnnr = gt_mkal-plnnr
     AND plnal = gt_mkal-alnal.

  IF gt_plas IS NOT INITIAL.
    SORT gt_plas BY plnty plnnr plnal plnkn.
    DELETE ADJACENT DUPLICATES FROM gt_plas COMPARING plnty plnnr plnal plnkn.
  ENDIF.

  IF gt_plas IS NOT INITIAL.
    SELECT plnty plnnr plnkn vornr bmsch meinh arbid
           lar01 vgw01 vge01
           lar02 vgw02 vge02
           lar03 vgw03 vge03
           lar04 vgw04 vge04
           lar05 vgw05 vge05
           lar06 vgw06 vge06
      FROM plpo
      INTO TABLE gt_plpo
       FOR ALL ENTRIES IN gt_plas
     WHERE plnty = gt_plas-plnty
       AND plnnr = gt_plas-plnnr
       AND plnkn = gt_plas-plnkn.

    IF gt_plpo IS NOT INITIAL.
      SORT gt_plpo BY plnty plnnr plnkn.
    ENDIF.
  ENDIF.

  IF gt_plpo IS NOT INITIAL.
    SELECT objid arbpl
      FROM crhd
      INTO TABLE gt_crhd
       FOR ALL ENTRIES IN gt_plpo
     WHERE objid = gt_plpo-arbid.

    IF gt_crhd IS NOT INITIAL.
      SORT gt_crhd BY objid.
    ENDIF.

    SELECT objid ktext
      FROM crtx
      INTO TABLE gt_crtx
       FOR ALL ENTRIES IN gt_plpo
     WHERE objid = gt_plpo-arbid
       AND spras = sy-langu.

    IF gt_crtx IS NOT INITIAL.
      SORT gt_crtx BY objid.
    ENDIF.
  ENDIF.

  SELECT matnr maktx
    FROM makt
    INTO TABLE gt_makt
     FOR ALL ENTRIES IN gt_mkal
   WHERE matnr = gt_mkal-matnr
     AND spras = 'EN'.

  IF gt_makt IS NOT INITIAL.
    SORT gt_makt BY matnr.
  ENDIF.

  LOOP AT gt_mkal INTO gs_mkal.

    CLEAR: gs_plko, lv_plko_ok.
    READ TABLE gt_plko INTO gs_plko
         WITH KEY plnty = gs_mkal-plnty
                  plnnr = gs_mkal-plnnr
                  plnal = gs_mkal-alnal
         BINARY SEARCH.
    IF sy-subrc = 0.
      lv_plko_ok = abap_true.
    ENDIF.

    CLEAR: gs_makt, lv_makt_ok.
    READ TABLE gt_makt INTO gs_makt
         WITH KEY matnr = gs_mkal-matnr
         BINARY SEARCH.
    IF sy-subrc = 0.
      lv_makt_ok = abap_true.
    ENDIF.

    LOOP AT gt_plas INTO gs_plas
      WHERE plnty = gs_mkal-plnty
        AND plnnr = gs_mkal-plnnr
        AND plnal = gs_mkal-alnal.

      READ TABLE gt_plpo INTO gs_plpo
           WITH KEY plnty = gs_plas-plnty
                    plnnr = gs_plas-plnnr
                    plnkn = gs_plas-plnkn
           BINARY SEARCH.

      IF sy-subrc <> 0.
        CONTINUE.
      ENDIF.

      CLEAR gs_alv.

      gs_alv-werks = gs_mkal-werks.
      gs_alv-matnr = gs_mkal-matnr.
      gs_alv-verid = gs_mkal-verid.
      gs_alv-plnnr = gs_mkal-plnnr.
      gs_alv-alnal = gs_mkal-alnal.
      gs_alv-plnty = gs_mkal-plnty.
      gs_alv-plnkn = gs_plas-plnkn.

      IF lv_makt_ok = abap_true.
        gs_alv-maktx = gs_makt-maktx.
      ENDIF.

      IF lv_plko_ok = abap_true.
        gs_alv-statu    = gs_plko-statu.
        gs_alv-verwe    = gs_plko-verwe.
        gs_alv-vagrp    = gs_plko-vagrp.
        gs_alv-plnme    = gs_plko-plnme.
        gs_alv-losvn    = gs_plko-losvn.
        gs_alv-datuv    = gs_plko-datuv.
        gs_alv-valid_to = gs_plko-valid_to.
      ENDIF.

      gs_alv-vornr = gs_plpo-vornr.
      gs_alv-bmsch = gs_plpo-bmsch.
      gs_alv-lar01 = gs_plpo-lar01.
      gs_alv-vgw01 = gs_plpo-vgw01.
      gs_alv-vge01 = gs_plpo-vge01.
      gs_alv-lar02 = gs_plpo-lar02.
      gs_alv-vgw02 = gs_plpo-vgw02.
      gs_alv-vge02 = gs_plpo-vge02.
      gs_alv-lar03 = gs_plpo-lar03.
      gs_alv-vgw03 = gs_plpo-vgw03.
      gs_alv-vge03 = gs_plpo-vge03.
      gs_alv-lar04 = gs_plpo-lar04.
      gs_alv-vgw04 = gs_plpo-vgw04.
      gs_alv-vge04 = gs_plpo-vge04.
      gs_alv-lar05 = gs_plpo-lar05.
      gs_alv-vgw05 = gs_plpo-vgw05.
      gs_alv-vge05 = gs_plpo-vge05.
      gs_alv-lar06 = gs_plpo-lar06.
      gs_alv-vgw06 = gs_plpo-vgw06.
      gs_alv-vge06 = gs_plpo-vge06.

      lv_arbid = gs_plpo-arbid.
      IF lv_arbid IS NOT INITIAL.
        READ TABLE gt_crhd INTO gs_crhd
             WITH KEY objid = lv_arbid
             BINARY SEARCH.
        IF sy-subrc = 0.
          gs_alv-arbpl = gs_crhd-arbpl.
        ENDIF.

        READ TABLE gt_crtx INTO gs_crtx
             WITH KEY objid = lv_arbid
             BINARY SEARCH.
        IF sy-subrc = 0.
          gs_alv-ktext = gs_crtx-ktext.
        ENDIF.
      ENDIF.

      IF gs_plpo-bmsch IS NOT INITIAL AND gs_plpo-meinh IS NOT INITIAL.
        CLEAR lv_bmsch_mt.
        CALL FUNCTION 'MD_CONVERT_MATERIAL_UNIT'
          EXPORTING
            i_matnr  = gs_mkal-matnr
            i_in_me  = gs_plpo-meinh
            i_out_me = 'MT'
            i_menge  = gs_plpo-bmsch
          IMPORTING
            e_menge  = lv_bmsch_mt
          EXCEPTIONS
            error_in_application = 1
            error                = 2
            OTHERS               = 3.
        IF sy-subrc = 0.
          gs_alv-bmsch_mt = lv_bmsch_mt.
        ENDIF.
      ENDIF.

      APPEND gs_alv TO gt_alv.

    ENDLOOP.

  ENDLOOP.

  gv_records = lines( gt_alv ).
  SORT gt_alv BY werks matnr plnnr plnkn vornr.

ENDFORM.


