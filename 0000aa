FORM fetch_allocation_data.

  DATA: lt_plmz_keys TYPE STANDARD TABLE OF ty_afko,
        lt_plas_keys TYPE STANDARD TABLE OF ty_afko,
        lt_plpo_tmp  TYPE STANDARD TABLE OF ty_plpo.

  IF gt_afko IS INITIAL.
    RETURN.
  ENDIF.

  IF gt_resb IS NOT INITIAL.
    lt_plmz_keys = gt_afko.
    SORT lt_plmz_keys BY plnty plnnr plnal stlty stlnr stlal.
    DELETE ADJACENT DUPLICATES FROM lt_plmz_keys
      COMPARING plnty plnnr plnal stlty stlnr stlal.

    IF lt_plmz_keys IS NOT INITIAL.
      SELECT plnty plnnr plnal stlty stlnr stlal stlkn plnkn werks
        FROM plmz
        INTO TABLE gt_plmz
         FOR ALL ENTRIES IN lt_plmz_keys
       WHERE plnty = lt_plmz_keys-plnty
         AND plnnr = lt_plmz_keys-plnnr
         AND plnal = lt_plmz_keys-plnal
         AND stlty = lt_plmz_keys-stlty
         AND stlnr = lt_plmz_keys-stlnr
         AND stlal = lt_plmz_keys-stlal
         AND loekz = space.

      IF gt_plmz IS NOT INITIAL.
        SORT gt_plmz BY plnty plnnr plnal stlty stlnr stlal stlkn werks.
      ENDIF.
    ENDIF.
  ENDIF.

  lt_plas_keys = gt_afko.
  SORT lt_plas_keys BY plnty plnnr plnal.
  DELETE ADJACENT DUPLICATES FROM lt_plas_keys
    COMPARING plnty plnnr plnal.

  IF lt_plas_keys IS NOT INITIAL.
    SELECT plnty plnnr plnal plnkn
      FROM plas
      INTO TABLE gt_plas
       FOR ALL ENTRIES IN lt_plas_keys
     WHERE plnty = lt_plas_keys-plnty
       AND plnnr = lt_plas_keys-plnnr
       AND plnal = lt_plas_keys-plnal
       AND loekz = space.

    IF gt_plas IS NOT INITIAL.
      SORT gt_plas BY plnty plnnr plnal plnkn.
    ENDIF.
  ENDIF.

  IF gt_plmz IS NOT INITIAL.
    SELECT plnty plnnr plnkn vornr arbid aedat
      FROM plpo
      INTO TABLE gt_plpo
       FOR ALL ENTRIES IN gt_plmz
     WHERE plnty = gt_plmz-plnty
       AND plnnr = gt_plmz-plnnr
       AND plnkn = gt_plmz-plnkn
       AND loekz = space.
  ENDIF.

  IF gt_plas IS NOT INITIAL.
    SELECT plnty plnnr plnkn vornr arbid aedat
      FROM plpo
      INTO TABLE lt_plpo_tmp
       FOR ALL ENTRIES IN gt_plas
     WHERE plnty = gt_plas-plnty
       AND plnnr = gt_plas-plnnr
       AND plnkn = gt_plas-plnkn
       AND loekz = space.

    IF lt_plpo_tmp IS NOT INITIAL.
      APPEND LINES OF lt_plpo_tmp TO gt_plpo.
    ENDIF.
  ENDIF.

  IF gt_plpo IS NOT INITIAL.
    SORT gt_plpo BY plnty plnnr plnkn vornr aedat.
    DELETE ADJACENT DUPLICATES FROM gt_plpo
      COMPARING plnty plnnr plnkn vornr aedat.
    SORT gt_plpo BY plnty plnnr plnkn.
  ENDIF.

  IF gt_plpo IS NOT INITIAL.
    SELECT objid arbpl
      FROM crhd
      INTO TABLE gt_crhd
       FOR ALL ENTRIES IN gt_plpo
     WHERE objid = gt_plpo-arbid.

    IF gt_crhd IS NOT INITIAL.
      SORT gt_crhd BY objid.
    ENDIF.
  ENDIF.

ENDFORM.


FORM get_allocation USING    iv_plnty TYPE plnty
                             iv_plnnr TYPE plnnr
                             iv_plnal TYPE plnal
                             iv_stlty TYPE stlty
                             iv_stlnr TYPE stlnr
                             iv_stlal TYPE stlal
                             iv_stlkn TYPE stlkn
                             iv_werks TYPE werks_d
                    CHANGING ev_vornr TYPE plpo-vornr
                             ev_arbpl TYPE crhd-arbpl.

  DATA: lv_plnkn      TYPE plpo-plnkn,
        lv_arbid      TYPE plpo-arbid,
        lv_plas_idx   TYPE sy-tabix,
        lv_plpo_idx   TYPE sy-tabix,
        lv_use_plmz   TYPE abap_bool,
        ls_plmz       TYPE ty_plmz,
        ls_plas       TYPE ty_plas,
        ls_plpo       TYPE ty_plpo,
        ls_crhd       TYPE ty_crhd,
        ls_best_plpo  TYPE ty_plpo.

  CLEAR: ev_vornr, ev_arbpl, lv_use_plmz.

  CLEAR ls_plmz.
  READ TABLE gt_plmz INTO ls_plmz
       WITH KEY plnty = iv_plnty
                plnnr = iv_plnnr
                plnal = iv_plnal
                stlty = iv_stlty
                stlnr = iv_stlnr
                stlal = iv_stlal
                stlkn = iv_stlkn
                werks = iv_werks
       BINARY SEARCH.

  IF sy-subrc = 0.
    lv_plnkn    = ls_plmz-plnkn.
    lv_use_plmz = abap_true.
  ELSE.
    READ TABLE gt_plas TRANSPORTING NO FIELDS
         WITH KEY plnty = iv_plnty
                  plnnr = iv_plnnr
                  plnal = iv_plnal
         BINARY SEARCH.
    IF sy-subrc <> 0.
      RETURN.
    ENDIF.
    lv_plas_idx = sy-tabix.
  ENDIF.

  CLEAR ls_best_plpo.

  IF lv_use_plmz = abap_true.
    READ TABLE gt_plpo TRANSPORTING NO FIELDS
         WITH KEY plnty = iv_plnty
                  plnnr = iv_plnnr
                  plnkn = lv_plnkn
         BINARY SEARCH.
    IF sy-subrc = 0.
      lv_plpo_idx = sy-tabix.

      LOOP AT gt_plpo INTO ls_plpo FROM lv_plpo_idx.
        IF ls_plpo-plnty <> iv_plnty
           OR ls_plpo-plnnr <> iv_plnnr
           OR ls_plpo-plnkn <> lv_plnkn.
          EXIT.
        ENDIF.

        IF ls_best_plpo-vornr IS INITIAL
           OR ls_plpo-vornr < ls_best_plpo-vornr.
          ls_best_plpo = ls_plpo.
        ELSEIF ls_plpo-vornr = ls_best_plpo-vornr
           AND ls_plpo-aedat > ls_best_plpo-aedat.
          ls_best_plpo = ls_plpo.
        ENDIF.
      ENDLOOP.
    ENDIF.
  ELSE.
    LOOP AT gt_plas INTO ls_plas FROM lv_plas_idx.
      IF ls_plas-plnty <> iv_plnty
         OR ls_plas-plnnr <> iv_plnnr
         OR ls_plas-plnal <> iv_plnal.
        EXIT.
      ENDIF.

      READ TABLE gt_plpo TRANSPORTING NO FIELDS
           WITH KEY plnty = iv_plnty
                    plnnr = iv_plnnr
                    plnkn = ls_plas-plnkn
           BINARY SEARCH.
      IF sy-subrc = 0.
        lv_plpo_idx = sy-tabix.

        LOOP AT gt_plpo INTO ls_plpo FROM lv_plpo_idx.
          IF ls_plpo-plnty <> iv_plnty
             OR ls_plpo-plnnr <> iv_plnnr
             OR ls_plpo-plnkn <> ls_plas-plnkn.
            EXIT.
          ENDIF.

          IF ls_best_plpo-vornr IS INITIAL
             OR ls_plpo-vornr < ls_best_plpo-vornr.
            ls_best_plpo = ls_plpo.
          ELSEIF ls_plpo-vornr = ls_best_plpo-vornr
             AND ls_plpo-aedat > ls_best_plpo-aedat.
            ls_best_plpo = ls_plpo.
          ENDIF.
        ENDLOOP.
      ENDIF.
    ENDLOOP.
  ENDIF.

  IF ls_best_plpo-vornr IS NOT INITIAL.
    ev_vornr = ls_best_plpo-vornr.
    lv_arbid = ls_best_plpo-arbid.

    IF lv_arbid IS NOT INITIAL.
      CLEAR ls_crhd.
      READ TABLE gt_crhd INTO ls_crhd
           WITH KEY objid = lv_arbid
           BINARY SEARCH.
      IF sy-subrc = 0.
        ev_arbpl = ls_crhd-arbpl.
      ENDIF.
    ENDIF.
  ENDIF.

ENDFORM.


