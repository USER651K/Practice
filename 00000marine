    CLEAR lv_mengeout.

    IF gs_final-meins = lc_mt.
      gs_final-wtmt = gs_final-quantity .
    ELSEIF gs_final-meins = lc_kg.
      gs_final-wtmt = gs_final-quantity / 1000.
    ELSEIF ( gs_final-meins NE lc_mt AND gs_final-meins NE lc_kg ).
      CALL FUNCTION 'MD_CONVERT_MATERIAL_UNIT'
        EXPORTING
          i_matnr              = gs_final-matnr
          i_in_me              = gs_final-meins
          i_out_me             = lc_mtt
          i_menge              = gs_final-quantity
        IMPORTING
          e_menge              = lv_mengeout
        EXCEPTIONS
          error_in_application = 1
          error                = 2
          OTHERS               = 3.
      IF sy-subrc = 0.
        gs_final-wtmt = lv_mengeout.
      ELSE.
        gs_final-wtmt = gs_final-quantity / 10.
      ENDIF.
    ENDIF.

    READ TABLE lt_ekpo INTO DATA(ls_ekpo) WITH KEY ebeln = wa_bill-aubel ebelp = wa_bill-aupos+1(5).
    IF sy-subrc = 0.
      gs_final-submi = ls_ekpo-submi .
      gs_final-bednr = ls_ekpo-bednr .
    ENDIF.

*&-- Marine Insurance: Populate new fields --*
    gs_final-bukrs = wa_bill-bukrs.

    IF wa_bill-vkorg < '5000' OR wa_bill-vkorg = '5020'.
      gs_final-export_flag = 'X'.
    ELSE.
      CLEAR gs_final-export_flag.
    ENDIF.

    CLEAR gs_t001w.
    READ TABLE gt_t001w INTO gs_t001w WITH KEY werks = wa_bill-werks BINARY SEARCH.
    IF sy-subrc = 0.
      gs_final-plant_desc = gs_t001w-name1.
    ENDIF.

    IF wa_bkpf IS NOT INITIAL.
      CLEAR wa_bseg.
      READ TABLE it_bseg INTO wa_bseg WITH KEY bukrs = wa_bkpf-bukrs
                                               belnr = wa_bkpf-belnr
                                               gjahr = wa_bkpf-gjahr
