      gs_final-sales_inr = gs_final-sum_amt.
    ENDIF.

    gs_final-cif_10pct = gs_final-sales_inr * '1.10'.

    APPEND gs_final TO gt_final.
    CLEAR: gs_final,wa_bill_t.
  ENDLOOP.

  SORT gt_final BY inv_no inv_item.

  DELETE gt_final WHERE fkart CP 'STO*'.
  DELETE gt_final WHERE inv_type_text CP 'STO*'.
  DELETE gt_final WHERE gl_code = '3010000024'.

  IF gt_final[] IS NOT INITIAL.
    IF ra1 = 'X'.
      PERFORM populate_fieldcat.
      PERFORM display_alv.
    ELSE.
      PERFORM write_file.
    ENDIF.
  ELSE.
    MESSAGE 'No records found' TYPE 'I'.
    LEAVE LIST-PROCESSING.
  ENDIF.
