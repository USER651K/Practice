      SET PARAMETER ID 'AGN' FIELD lv_vbeln.
      CALL TRANSACTION 'VA23' WITH AUTHORITY-CHECK AND SKIP FIRST SCREEN.
    ENDIF.
  ELSEIF rs_selfield-sel_tab_field  = 'GT_FINAL-SALES_ORDER_NO'.
