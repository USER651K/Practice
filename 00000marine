FORM fetch_data .
  DATA: lt_final LIKE TABLE OF gs_final,
        lv_mengeout TYPE ekpo-menge.

  FIELD-SYMBOLS <fs> LIKE gs_final.
  DATA : cnt TYPE int8.

  CONSTANTS: lc_kg TYPE char2 VALUE 'KG',
             lc_mtt TYPE mara-meins VALUE 'MT'.

  CONSTANTS: lc_mt(2) VALUE 'MT'.

  DATA: it_month_name TYPE TABLE OF t247, wa_month_name TYPE t247.

  SELECT a~vbeln a~fkart a~sfakn a~waerk a~vkorg a~vtweg a~kurrf a~kunrg
 a~kunag a~fkdat a~inco1 a~inco2 a~mwsbk a~knumv a~zterm a~land1 a~regio
 a~bstnk_vf a~fksto a~taxk1 a~taxk2 b~posnr b~fkimg b~vrkme b~netwr
 b~matnr b~vkgrp b~vkbur b~aubel b~aupos b~vgbel b~vgpos b~spart b~werks
b~ktgrm a~belnr a~bzirk a~kdgrp b~pstyv b~meins b~fklmg b~ntgew b~brgew b~arktx
b~mwsbp b~wkreg a~xblnr b~lgort a~bukrs FROM vbrk AS a INNER JOIN vbrp AS b ON a~vbeln = b~vbeln INNER JOIN mara AS c ON b~matnr = c~matnr
INTO TABLE it_bill WHERE a~vbeln IN s_vbeln AND a~bukrs IN s_bukrs
AND a~fkart IN s_fkart AND a~vkorg IN s_vkorg AND a~vtweg IN s_vtweg
AND b~spart IN s_spart AND a~fkdat IN s_fkdat AND b~vkbur IN s_vkbur
AND b~vkgrp IN s_vkgrp AND b~werks IN s_werks AND a~kdgrp IN s_kdgrp
AND a~kunag IN s_kunnr AND b~matnr IN s_matnr AND a~vbtyp IN s_vbtyp
AND c~matkl IN s_matkl AND a~rfbsk <> 'E' AND b~aubel IN s_aubel .

  SORT it_bill BY fksto. DELETE it_bill WHERE fksto NE space.
  SORT it_bill BY sfakn. DELETE it_bill WHERE sfakn NE space.

  DELETE it_bill WHERE NOT ( bukrs = '1010' OR bukrs = '1020' OR bukrs >= '5000' ).

  IF s_lgort IS NOT INITIAL.
    DELETE it_bill WHERE lgort NOT IN s_lgort.
  ENDIF.

  SORT it_bill BY fkart.
  SORT it_bill BY vbeln.

  IF it_bill[] IS NOT INITIAL.

    SELECT matnr,extwg FROM mara INTO TABLE @DATA(gt_mara_new) FOR ALL ENTRIES IN @it_bill
                                                  WHERE matnr EQ @it_bill-matnr.
    IF sy-subrc EQ 0.
      SELECT extwg,ewbez FROM twewt INTO TABLE @DATA(gt_twewt) FOR ALL ENTRIES IN @gt_mara_new
                                                               WHERE extwg EQ @gt_mara_new-extwg
                                                               AND   spras EQ 'E'.
    ENDIF.
    LOOP AT it_bill INTO wa_bill.
      wa_bill-awkey = wa_bill-vbeln.
      MODIFY it_bill FROM wa_bill TRANSPORTING awkey.
      CLEAR wa_bill.
    ENDLOOP.
    SELECT bukrs belnr gjahr awkey budat FROM bkpf INTO TABLE it_bkpf FOR ALL ENTRIES IN it_bill
                                                    WHERE awtyp = 'VBRK ' AND awkey EQ it_bill-awkey.

    IF it_bkpf[] IS NOT INITIAL.
      SELECT bukrs belnr gjahr gsber hkont matnr FROM bseg INTO TABLE it_bseg
        FOR ALL ENTRIES IN it_bkpf
        WHERE bukrs = it_bkpf-bukrs AND belnr = it_bkpf-belnr AND gjahr = it_bkpf-gjahr.
      SORT it_bseg BY bukrs belnr gjahr matnr.
    ENDIF.

    SELECT vbeln erdat bolnr traid lfdat kunnr xabln bldat wadat_ist sdabw
     FROM likp INTO TABLE it_likp
      FOR ALL ENTRIES IN it_bill
       WHERE vbeln = it_bill-vgbel.

    SELECT ebeln ebelp lgort FROM ekpo INTO TABLE it_ekpo
   FOR ALL ENTRIES IN it_bill WHERE ebeln = it_bill-aubel.

    SELECT vbeln posnr  matnr charg brgew  gewei vgpos FROM lips
     INTO TABLE gt_lips FOR ALL ENTRIES IN it_bill
       WHERE vbeln = it_bill-vgbel.

    IF  gt_lips[] IS NOT INITIAL.
      SELECT venum vepos vbeln posnr FROM vepo INTO TABLE it_vepo FOR ALL ENTRIES IN gt_lips
      WHERE vbeln = gt_lips-vbeln AND posnr = gt_lips-posnr.
    ENDIF.

    LOOP AT   it_bill ASSIGNING FIELD-SYMBOL(<lfs_bill>).
      SELECT vbeln , posnr , vgpos FROM lips INTO TABLE @DATA(it_temp) WHERE vgpos = @<lfs_bill>-posnr AND vbeln  = @<lfs_bill>-vgbel.
      IF sy-subrc IS INITIAL.
        SELECT COUNT(*) FROM vepo INTO @cnt FOR ALL ENTRIES IN @it_temp WHERE vbeln = @it_temp-vbeln AND posnr = @it_temp-posnr.
        IF sy-subrc IS INITIAL.
          <lfs_bill>-pallet = cnt.
        ENDIF.
      ENDIF.
      CLEAR cnt.
    ENDLOOP.

    IF it_likp[] IS NOT INITIAL.
      SELECT vbelv posnv vbeln posnn FROM vbfa
        INTO TABLE gt_vbfa3 FOR ALL ENTRIES IN it_likp
        WHERE vbelv EQ it_likp-vbeln AND vbtyp_n EQ '8'.
      IF sy-subrc EQ 0.
        SORT gt_vbfa3 BY  vbelv.
      ENDIF.
    ENDIF.

    SELECT * FROM tvkot INTO TABLE gt_tvkot
      WHERE spras EQ sy-langu.
    IF sy-subrc EQ 0.
      SORT gt_tvkot BY vkorg.
    ENDIF.

    IF gt_vbfa3[] IS NOT INITIAL.
      SELECT tknum exti1 tndr_trkid tdlnr
       signi exti2 tndr_actp FROM vttk
        INTO TABLE gt_vttk
        FOR ALL ENTRIES IN gt_vbfa3
        WHERE tknum EQ gt_vbfa3-vbeln.
      IF sy-subrc EQ 0.
        SORT gt_vttk BY tknum.
        SELECT * FROM lfa1 INTO TABLE gt_lfa1
         FOR ALL ENTRIES IN gt_vttk
          WHERE lifnr EQ gt_vttk-tdlnr.
        IF sy-subrc EQ 0.
          SORT gt_lfa1 BY lifnr .
        ENDIF.
      ENDIF.

      SELECT * FROM zp2pweighb INTO TABLE @DATA(gt_zp2pweighb)
       FOR ALL ENTRIES IN @gt_vbfa3
        WHERE tknum EQ @gt_vbfa3-vbeln.
      IF sy-subrc EQ 0.
        SORT gt_zp2pweighb BY tknum.
      ENDIF.

