      gs_final-dis_amt = gs_final-dis_amt + gs_konv-kwert.
    ENDIF.
    CLEAR gs_konv.
    READ TABLE gt_konv INTO gs_konv WITH KEY knumv = wa_bill-knumv kposn = wa_bill-posnr kschl = 'K005'.
    IF sy-subrc IS INITIAL.
      IF gs_konv-krech EQ 'A'.
        gs_final-dis_prcnt = gs_final-dis_prcnt + ( gs_konv-kbetr / 10 ).
      ELSE.
        gs_final-dis_prcnt = gs_final-dis_prcnt + gs_konv-kbetr .
      ENDIF.
      gs_final-dis_amt = gs_final-dis_amt + gs_konv-kwert.
    ENDIF.
    CLEAR gs_konv.
    READ TABLE gt_konv INTO gs_konv WITH KEY knumv = wa_bill-knumv kposn = wa_bill-posnr kschl = 'ZEDP'.
    IF sy-subrc IS INITIAL.
      IF gs_konv-krech EQ 'A'.
        gs_final-dis_prcnt = gs_final-dis_prcnt + ( gs_konv-kbetr / 10 ).
      ELSE.
        gs_final-dis_prcnt = gs_final-dis_prcnt + gs_konv-kbetr .
      ENDIF.
      gs_final-dis_amt = gs_final-dis_amt + gs_konv-kwert.
    ENDIF.
    CLEAR gs_konv.
    READ TABLE gt_konv INTO gs_konv WITH KEY knumv = wa_bill-knumv kposn = wa_bill-posnr kschl = 'ZEDQ'.
    IF sy-subrc IS INITIAL.
      IF gs_konv-krech EQ 'A'.
        gs_final-dis_prcnt = gs_final-dis_prcnt + ( gs_konv-kbetr / 10 ).
      ELSE.
        gs_final-dis_prcnt = gs_final-dis_prcnt + gs_konv-kbetr .
      ENDIF.
      gs_final-dis_amt = gs_final-dis_amt + gs_konv-kwert.
    ENDIF.
    CLEAR gs_konv.
    READ TABLE gt_konv INTO gs_konv WITH KEY knumv = wa_bill-knumv kposn = wa_bill-posnr kschl = 'ZEHD'.
    IF sy-subrc IS INITIAL.
      IF gs_konv-krech EQ 'A'.
        gs_final-dis_prcnt = gs_final-dis_prcnt + ( gs_konv-kbetr / 10 ).
      ELSE.
        gs_final-dis_prcnt = gs_final-dis_prcnt + gs_konv-kbetr .
      ENDIF.
      gs_final-dis_amt = gs_final-dis_amt + gs_konv-kwert.
    ENDIF.

    CLEAR gs_konv.
    READ TABLE gt_konv INTO gs_konv WITH KEY knumv = wa_bill-knumv kposn = wa_bill-posnr kschl = 'ZDIE'.
    IF sy-subrc IS INITIAL.
      IF gs_konv-krech EQ 'A'.
        IF gs_konv-kbetr LE 0.
          gs_konv-kbetr = gs_konv-kbetr * -1.
          gs_konv-kwert = gs_konv-kwert * -1.
        ELSE.
          gs_konv-kwert = gs_konv-kwert.
        ENDIF.
        gs_final-dis_prcnt = gs_final-dis_prcnt + ( gs_konv-kbetr ).
      ELSE.
        gs_final-dis_prcnt = gs_final-dis_prcnt + gs_konv-kbetr .
      ENDIF.
      gs_final-dis_amt = gs_final-dis_amt + gs_konv-kwert.
    ENDIF.

    READ TABLE gt_konv INTO gs_konv WITH KEY knumv = wa_bill-knumv kposn = wa_bill-posnr kschl = 'ZDS1'.
    IF sy-subrc IS INITIAL.
      IF gs_konv-krech EQ 'A'.
        IF gs_konv-kbetr LE 0.
          gs_konv-kbetr = gs_konv-kbetr * -1.
          gs_konv-kwert = gs_konv-kwert * -1.
        ELSE.
          gs_konv-kwert = gs_konv-kwert.
        ENDIF.
        gs_final-dis_prcnt = gs_final-dis_prcnt + ( gs_konv-kbetr ).
      ELSE.
        gs_final-dis_prcnt = gs_final-dis_prcnt + gs_konv-kbetr .
      ENDIF.
      gs_final-dis_amt = gs_final-dis_amt + gs_konv-kwert.
    ENDIF.

    CLEAR gs_konv.
    READ TABLE gt_konv INTO gs_konv WITH KEY knumv = wa_bill-knumv kposn = wa_bill-posnr kschl = 'BO02'.
    IF sy-subrc IS INITIAL.
      IF gs_konv-krech EQ 'A'.
        gs_final-rebate_prcnt = gs_final-rebate_prcnt + ( gs_konv-kbetr / 10 ).
      ELSE.
        gs_final-rebate_prcnt = gs_final-rebate_prcnt + gs_konv-kbetr .
      ENDIF.
      gs_final-rebate_amt = gs_final-rebate_amt + gs_konv-kwert.
    ENDIF.
    CLEAR gs_konv.
    READ TABLE gt_konv INTO gs_konv WITH KEY knumv = wa_bill-knumv kposn = wa_bill-posnr kschl = 'BO03'.
    IF sy-subrc IS INITIAL.
      IF gs_konv-krech EQ 'A'.
        gs_final-rebate_prcnt = gs_final-rebate_prcnt + ( gs_konv-kbetr / 10 ).
      ELSE.
        gs_final-rebate_prcnt = gs_final-rebate_prcnt + gs_konv-kbetr .
      ENDIF.
      gs_final-rebate_amt = gs_final-rebate_amt + gs_konv-kwert.
    ENDIF.

    CLEAR gs_konv.
    READ TABLE gt_konv INTO gs_konv WITH KEY knumv = wa_bill-knumv kposn = wa_bill-posnr kschl = 'ZFTP'.
    IF sy-subrc IS INITIAL.
      gs_final-ftp_kawrt = gs_konv-kwert.
    ENDIF.

    READ TABLE gt_konv INTO gs_konv WITH KEY knumv = wa_bill-knumv kposn = wa_bill-posnr kschl = 'ZFR7'.
    IF sy-subrc IS INITIAL.
      gs_final-freight_prcnt = gs_konv-kbetr.
      gs_final-freight_price = gs_konv-kwert.
    ENDIF.

    IF wa_bill-fkart = 'ZISL'.
      READ TABLE lt_prcd INTO DATA(ls_prcd) WITH KEY ebeln = wa_bill-aubel kposn = wa_bill-aupos
                                                     BINARY SEARCH.
      IF sy-subrc = 0.
        gs_final-ftp_kawrt = ls_prcd-kbetr.
        CLEAR ls_prcd.
      ENDIF.
    ENDIF.

    IF gs_final-gi_date IS NOT INITIAL AND gs_final-sales_order_dt IS NOT INITIAL.
      gs_final-actual_supply_tm = gs_final-gi_date - gs_final-sales_order_dt.
    ENDIF.

    gs_final-grand_total_amt = gs_final-grand_total_amt.

    IF  wa_bill-fkart = 'ZRE' OR wa_bill-fkart = 'ZG2' OR wa_bill-fkart = 'ZDRE'.
      IF gs_final-grand_total_amt < 0 AND wa_bill-fkart = 'ZG2'.
        gs_final-net_weight      = gs_final-net_weight.
        gs_final-net_wt_qtl      = gs_final-net_wt_qtl.
        gs_final-quantity        = gs_final-quantity.
        gs_final-so_quantity     = gs_final-so_quantity.
      ELSE.
        gs_final-net_weight      = gs_final-net_weight * -1.
        gs_final-net_wt_qtl      = gs_final-net_wt_qtl * -1.
        gs_final-quantity        = gs_final-quantity * -1.
        gs_final-so_quantity     = gs_final-so_quantity * -1.
      ENDIF.
      gs_final-exmill_rate     = gs_final-exmill_rate * -1.
      gs_final-ex_mill         = gs_final-ex_mill * -1.
      gs_final-sale_price      = gs_final-sale_price * -1.
      gs_final-commission_rate = gs_final-commission_rate * -1.
      gs_final-commission      = gs_final-commission * -1.
      gs_final-excess_rate     = gs_final-excess_rate * -1.
      gs_final-excess_amt      =  gs_final-excess_amt * -1.
      gs_final-ap_freight      = gs_final-ap_freight * -1.
      gs_final-adpack_charge   = gs_final-adpack_charge * -1.
      gs_final-add_ins         = gs_final-add_ins * -1.
      gs_final-vat_amt         = gs_final-vat_amt * -1.
      gs_final-cgst_amt         = gs_final-cgst_amt * -1.
      gs_final-sgst_amt         = gs_final-sgst_amt * -1.
      gs_final-igst_amt         = gs_final-igst_amt * -1.
      gs_final-cst_amt         = gs_final-cst_amt * -1.
      gs_final-tcs_amt         = gs_final-tcs_amt * -1.
      gs_final-dis_amt         = gs_final-dis_amt * -1.
      gs_final-rebate_amt      = gs_final-rebate_amt * -1.
      gs_final-net_amt         = gs_final-net_amt * -1.
      gs_final-net_amt_c       = gs_final-net_amt_c  * -1.
      gs_final-grand_total_amt = gs_final-grand_total_amt * -1.
      gs_final-ftp_kawrt = gs_final-ftp_kawrt * -1.
    ENDIF.
    IF gs_final-kurrf < 0.
      gs_final-kurrf = gs_final-kurrf * -1.
    ENDIF.
    gs_final-exrate = gs_final-net_amt_c /  gs_final-kurrf.

    READ TABLE it_bill_t INTO wa_bill_t WITH KEY vbeln = gs_final-inv_no posnr = gs_final-inv_item.
    IF sy-subrc = 0.
    ELSE.
      CLEAR:gs_final-tndr_actp.
    ENDIF.

    gs_final-zadv_frt_inr = ( gs_final-ap_freight ) * ( gs_final-kurrf ).
