*&---------------------------------------------------------------------*
*&      Form  MANIPULATE_BSAD
*&---------------------------------------------------------------------*
FORM manipulate_bsad .

  DATA: ls_test1 TYPE ty_test.

  FIELD-SYMBOLS: <fs_fagl>  TYPE ty_fagl,
                 <fs_bsad>  TYPE ty_bsad,
                 <fs_bsad2> TYPE ty_bsad.

  SORT gt_bsad BY bukrs belnr gjahr buzei.

  LOOP AT gt_fagl_bsad ASSIGNING <fs_fagl>.
    CLEAR ls_test1.
    ls_test1-ryear  = <fs_fagl>-ryear.
    ls_test1-docnr  = <fs_fagl>-docnr.
    ls_test1-rbukrs = <fs_fagl>-rbukrs.
    ls_test1-docln  = <fs_fagl>-docln.
    ls_test1-prctr  = <fs_fagl>-prctr.

    IF <fs_fagl>-bschl BETWEEN '01' AND '08'.
      IF <fs_fagl>-hsl >= 0.
        ls_test1-amt_dbt = <fs_fagl>-hsl.
      ELSE.
        ls_test1-amt_cdt = <fs_fagl>-hsl * '-1'.
      ENDIF.
    ELSEIF <fs_fagl>-bschl BETWEEN '11' AND '18'.
      IF <fs_fagl>-hsl >= 0.
        ls_test1-amt_dbt = <fs_fagl>-hsl.
      ELSE.
        ls_test1-amt_cdt = <fs_fagl>-hsl * '-1'.
      ENDIF.
    ELSEIF <fs_fagl>-bschl EQ '09'.
      ls_test1-advance = <fs_fagl>-hsl.
    ELSEIF <fs_fagl>-bschl EQ '19'.
      ls_test1-advance = <fs_fagl>-hsl.
    ENDIF.

    READ TABLE gt_bsad ASSIGNING <fs_bsad>
      WITH KEY bukrs = <fs_fagl>-rbukrs
               belnr = <fs_fagl>-docnr
               gjahr = <fs_fagl>-ryear
      BINARY SEARCH.
    IF sy-subrc = 0.
      READ TABLE gt_bsad ASSIGNING <fs_bsad2>
        WITH KEY bukrs = <fs_fagl>-rbukrs
                 belnr = <fs_fagl>-docnr
                 gjahr = <fs_fagl>-ryear
                 buzei = <fs_fagl>-buzei
        BINARY SEARCH.
      IF sy-subrc = 0.
        ls_test1-kunnr = <fs_bsad2>-kunnr.
      ELSE.
        ls_test1-kunnr = <fs_bsad>-kunnr.
      ENDIF.
      COLLECT ls_test1 INTO gt_test1.
    ENDIF.
  ENDLOOP.

  IF gt_test1 IS NOT INITIAL.
    SELECT kunnr name1 ort01 ktokd regio kukla
    INTO TABLE gt_kna1
    FROM kna1
    FOR ALL ENTRIES IN gt_test1
    WHERE kunnr = gt_test1-kunnr.
  ENDIF.

ENDFORM.


