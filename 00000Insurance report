*&---------------------------------------------------------------------*
*&      Form  MOVE_TO_FINAL
*&---------------------------------------------------------------------*
FORM move_to_final.

  DATA: lv_dayno  TYPE i,
        lv_netval TYPE vlcur12.

  FIELD-SYMBOLS: <fs_test>   TYPE ty_test,
                 <fs_bsad>   TYPE ty_bsad,
                 <fs_bsid>   TYPE ty_bsad,
                 <fs_kna1>   TYPE ty_kna1,
                 <fs_kna1r>  TYPE ty_kna1_r,
                 <fs_pa0001> TYPE ty_pa0001,
                 <fs_pa0006> TYPE ty_pa0006,
                 <fs_t077x>  TYPE t077x,
                 <fs_t005u>  TYPE t005u,
                 <fs_fagl>   TYPE ty_fagl,
                 <fs_dtl>    TYPE ty_final_dtl.

  DATA: ls_final_dtl TYPE ty_final_dtl,
        ls_final     TYPE ty_final.

* Pre-sort all lookup tables ONCE for BINARY SEARCH
  SORT gt_kna1   BY kunnr.
  SORT it_kna1_r BY kunnr.
  SORT it_pa0001 BY pernr.
  SORT it_pa0006 BY pernr.
  SORT it_t077x  BY ktokd.
  SORT it_t005u  BY bland.
  SORT gt_bsad   BY bukrs belnr gjahr.
  SORT gt_bsid   BY bukrs belnr gjahr.
  SORT gt_fagl_bsid BY rbukrs ryear docnr buzei.

*----------------------------------------------------------------------*
* Process cleared items (gt_test1 from BSAD)
*----------------------------------------------------------------------*
  LOOP AT gt_test1 ASSIGNING <fs_test>.
    CLEAR ls_final_dtl.

    ls_final_dtl-kunnr = <fs_test>-kunnr.
    ls_final_dtl-prctr = <fs_test>-prctr.

    READ TABLE gt_kna1 ASSIGNING <fs_kna1>
      WITH KEY kunnr = <fs_test>-kunnr BINARY SEARCH.
    IF sy-subrc = 0.
      ls_final_dtl-name1 = <fs_kna1>-name1.
      ls_final_dtl-ort01 = <fs_kna1>-ort01.
      ls_final_dtl-ktokd = <fs_kna1>-ktokd.
      ls_final_dtl-regio = <fs_kna1>-regio.
      IF <fs_kna1>-kukla = '04' OR <fs_kna1>-kukla = ''.
        ls_final_dtl-vkorg = 'Domestic'.
      ELSEIF <fs_kna1>-kukla = '05'.
        ls_final_dtl-vkorg = 'Export'.
      ENDIF.
      READ TABLE it_t077x ASSIGNING <fs_t077x>
        WITH KEY ktokd = <fs_kna1>-ktokd BINARY SEARCH.
      IF sy-subrc = 0.
        ls_final_dtl-ktokd_d = <fs_t077x>-txt30.
      ENDIF.
      READ TABLE it_t005u ASSIGNING <fs_t005u>
        WITH KEY bland = <fs_kna1>-regio BINARY SEARCH.
      IF sy-subrc = 0.
        ls_final_dtl-regio_d = <fs_t005u>-bezei.
      ENDIF.

      READ TABLE it_kna1_r ASSIGNING <fs_kna1r>
        WITH KEY kunnr = <fs_test>-kunnr BINARY SEARCH.
      IF sy-subrc = 0.
        ls_final_dtl-parvw = <fs_kna1r>-parvw.
        ls_final_dtl-pernr = <fs_kna1r>-pernr.
        READ TABLE it_pa0001 ASSIGNING <fs_pa0001>
          WITH KEY pernr = <fs_kna1r>-pernr BINARY SEARCH.
        IF sy-subrc = 0.
          ls_final_dtl-name = <fs_pa0001>-ename.
        ENDIF.
        READ TABLE it_pa0006 ASSIGNING <fs_pa0006>
          WITH KEY pernr = <fs_kna1r>-pernr BINARY SEARCH.
        IF sy-subrc = 0.
          ls_final_dtl-telnr = <fs_pa0006>-telnr.
        ENDIF.
      ENDIF.
    ENDIF.

    ls_final_dtl-docnr = <fs_test>-docnr.

    READ TABLE gt_bsad ASSIGNING <fs_bsad>
      WITH KEY bukrs = <fs_test>-rbukrs
               belnr = <fs_test>-docnr
               gjahr = <fs_test>-ryear
      BINARY SEARCH.
    IF sy-subrc = 0.
      ls_final_dtl-xblnr = <fs_bsad>-xblnr.
      ls_final_dtl-bldat = <fs_bsad>-bldat.
      ls_final_dtl-budat = <fs_bsad>-budat.
      ls_final_dtl-blart = <fs_bsad>-blart.
      ls_final_dtl-dudat = <fs_bsad>-duedt.
      ls_final_dtl-umskz = <fs_bsad>-umskz.
      ls_final_dtl-hkont = <fs_bsad>-hkont.
    ENDIF.

    lv_dayno = p_date - ls_final_dtl-dudat.
    ls_final_dtl-dayno = lv_dayno.

    ls_final_dtl-amt_dbt = <fs_test>-amt_dbt.
    ls_final_dtl-advance = <fs_test>-advance.
    ls_final_dtl-amt_cdt = <fs_test>-amt_cdt.
    lv_netval = ls_final_dtl-amt_dbt - ls_final_dtl-amt_cdt.
    ls_final_dtl-netval = lv_netval.

    IF ls_final_dtl-dudat GT p_date.
      ls_final_dtl-notdue = lv_netval.
    ELSEIF lv_dayno >= 0.
      IF lv_dayno <= gv_c1.
        ls_final_dtl-od1 = lv_netval.
      ELSEIF lv_dayno <= gv_c2.
        ls_final_dtl-od31 = lv_netval.
      ELSEIF lv_dayno <= gv_c3.
        ls_final_dtl-od61 = lv_netval.
      ELSEIF lv_dayno <= gv_c4.
        ls_final_dtl-od91 = lv_netval.
      ELSEIF lv_dayno <= gv_c5.
        ls_final_dtl-od121 = lv_netval.
      ELSE.
        ls_final_dtl-od181 = lv_netval.
      ENDIF.
    ENDIF.

    ls_final_dtl-total = lv_netval.
    APPEND ls_final_dtl TO gt_final_dtl.
  ENDLOOP.

*----------------------------------------------------------------------*
* Process open items (gt_test2 from BSID)
*----------------------------------------------------------------------*
  LOOP AT gt_test2 ASSIGNING <fs_test>.
    CLEAR ls_final_dtl.

    ls_final_dtl-kunnr = <fs_test>-kunnr.
    ls_final_dtl-prctr = <fs_test>-prctr.

    READ TABLE gt_kna1 ASSIGNING <fs_kna1>
      WITH KEY kunnr = <fs_test>-kunnr BINARY SEARCH.
    IF sy-subrc = 0.
      ls_final_dtl-name1 = <fs_kna1>-name1.
      ls_final_dtl-ort01 = <fs_kna1>-ort01.
      ls_final_dtl-ktokd = <fs_kna1>-ktokd.
      ls_final_dtl-regio = <fs_kna1>-regio.
      IF <fs_kna1>-kukla = '04' OR <fs_kna1>-kukla = ''.
        ls_final_dtl-vkorg = 'Domestic'.
      ELSEIF <fs_kna1>-kukla = '05'.
        ls_final_dtl-vkorg = 'Export'.
      ENDIF.
      READ TABLE it_t077x ASSIGNING <fs_t077x>
        WITH KEY ktokd = <fs_kna1>-ktokd BINARY SEARCH.
      IF sy-subrc = 0.
        ls_final_dtl-ktokd_d = <fs_t077x>-txt30.
      ENDIF.
      READ TABLE it_t005u ASSIGNING <fs_t005u>
        WITH KEY bland = <fs_kna1>-regio BINARY SEARCH.
      IF sy-subrc = 0.
        ls_final_dtl-regio_d = <fs_t005u>-bezei.
      ENDIF.

      READ TABLE it_kna1_r ASSIGNING <fs_kna1r>
        WITH KEY kunnr = <fs_test>-kunnr BINARY SEARCH.
      IF sy-subrc = 0.
        ls_final_dtl-parvw = <fs_kna1r>-parvw.
        ls_final_dtl-pernr = <fs_kna1r>-pernr.
        READ TABLE it_pa0001 ASSIGNING <fs_pa0001>
          WITH KEY pernr = <fs_kna1r>-pernr BINARY SEARCH.
        IF sy-subrc = 0.
          ls_final_dtl-name = <fs_pa0001>-ename.
        ENDIF.
        READ TABLE it_pa0006 ASSIGNING <fs_pa0006>
          WITH KEY pernr = <fs_kna1r>-pernr BINARY SEARCH.
        IF sy-subrc = 0.
          ls_final_dtl-telnr = <fs_pa0006>-telnr.
        ENDIF.
      ENDIF.
    ENDIF.

    ls_final_dtl-docnr = <fs_test>-docnr.

    READ TABLE gt_bsid ASSIGNING <fs_bsid>
      WITH KEY bukrs = <fs_test>-rbukrs
               belnr = <fs_test>-docnr
               gjahr = <fs_test>-ryear
      BINARY SEARCH.
    IF sy-subrc = 0.
      ls_final_dtl-xblnr = <fs_bsid>-xblnr.
      ls_final_dtl-bldat = <fs_bsid>-bldat.
      ls_final_dtl-budat = <fs_bsid>-budat.
      ls_final_dtl-blart = <fs_bsid>-blart.
      ls_final_dtl-dudat = <fs_bsid>-duedt.
      ls_final_dtl-umskz = <fs_bsid>-umskz.
      ls_final_dtl-hkont = <fs_bsid>-hkont.

      READ TABLE gt_fagl_bsid ASSIGNING <fs_fagl>
        WITH KEY rbukrs = <fs_bsid>-bukrs
                 ryear  = <fs_bsid>-gjahr
                 docnr  = <fs_bsid>-belnr
                 buzei  = <fs_bsid>-buzei
        BINARY SEARCH.
      IF sy-subrc = 0.
        ls_final_dtl-gsber = <fs_fagl>-rbusa.
      ENDIF.
    ENDIF.

    lv_dayno = p_date - ls_final_dtl-dudat.
    ls_final_dtl-dayno = lv_dayno.

    ls_final_dtl-amt_dbt = <fs_test>-amt_dbt.
    ls_final_dtl-advance = <fs_test>-advance.
    ls_final_dtl-amt_cdt = <fs_test>-amt_cdt.
    lv_netval = ls_final_dtl-amt_dbt - ls_final_dtl-amt_cdt.
    ls_final_dtl-netval = lv_netval.

    IF ls_final_dtl-dudat GT p_date.
      ls_final_dtl-notdue = lv_netval.
    ELSEIF lv_dayno >= 0.
      IF lv_dayno <= gv_c1.
        ls_final_dtl-od1 = lv_netval.
      ELSEIF lv_dayno <= gv_c2.
        ls_final_dtl-od31 = lv_netval.
      ELSEIF lv_dayno <= gv_c3.
        ls_final_dtl-od61 = lv_netval.
      ELSEIF lv_dayno <= gv_c4.
        ls_final_dtl-od91 = lv_netval.
      ELSEIF lv_dayno <= gv_c5.
        ls_final_dtl-od121 = lv_netval.
      ELSE.
        ls_final_dtl-od181 = lv_netval.
      ENDIF.
    ENDIF.

    ls_final_dtl-total = lv_netval.
    APPEND ls_final_dtl TO gt_final_dtl.
  ENDLOOP.

* Calculate total_due at detail level
  LOOP AT gt_final_dtl ASSIGNING <fs_dtl>.
    <fs_dtl>-total_due = <fs_dtl>-total - <fs_dtl>-notdue.
  ENDLOOP.

* Collect into summary
  IF rb_sum = 'X'.
    LOOP AT gt_final_dtl ASSIGNING <fs_dtl>.
      CLEAR ls_final.
      MOVE-CORRESPONDING <fs_dtl> TO ls_final.
      COLLECT ls_final INTO gt_final.
    ENDLOOP.
  ENDIF.

* Reconciliation account filter
  IF gt_final_dtl IS NOT INITIAL.
    SELECT kunnr akont FROM knb1 INTO TABLE it_knb1
    FOR ALL ENTRIES IN gt_final_dtl
    WHERE kunnr EQ gt_final_dtl-kunnr
    AND   akont IN s_hkont[].
  ENDIF.

  IF sy-subrc EQ 0.
    IF s_hkont IS NOT INITIAL.
      DELETE gt_final_dtl WHERE hkont NOT IN s_hkont.
    ENDIF.

    DATA: wa_knb1 TYPE ts_knb1.
    LOOP AT it_knb1 INTO wa_knb1.
      w_kunnr-sign = 'I'. w_kunnr-option = 'EQ'. w_kunnr-low = wa_knb1-kunnr.
      APPEND w_kunnr TO t_kunnr. CLEAR w_kunnr.
    ENDLOOP.

    DELETE gt_final_dtl WHERE kunnr NOT IN t_kunnr.
  ENDIF.

ENDFORM.


*&---------------------------------------------------------------------*
*&      Form  ADJUST_ADVANCE_IN_SUMMARY
*&---------------------------------------------------------------------*
* ZEXP: positive advance -> Not Due, negative -> reverse bucket adjust
* ZDOM/others: if Total Due = 0, adjust with Not Due
*----------------------------------------------------------------------*
FORM adjust_advance_in_summary.

  DATA: lv_adj TYPE vlcur12.

  FIELD-SYMBOLS: <fs_final> TYPE ty_final.

  LOOP AT gt_final ASSIGNING <fs_final>.

*--- ZEXP: Advance adjustment ---
    IF <fs_final>-ktokd = 'ZEXP'.

      IF <fs_final>-advance > 0.
        <fs_final>-notdue  = <fs_final>-notdue + <fs_final>-advance.
        <fs_final>-advance = 0.

      ELSEIF <fs_final>-advance < 0.
        lv_adj = <fs_final>-advance * -1.

*       Adjust overdue buckets from oldest to newest
*       1) >181 Days
        IF lv_adj > 0 AND <fs_final>-od181 > 0.
          IF <fs_final>-od181 >= lv_adj.
            <fs_final>-od181 = <fs_final>-od181 - lv_adj. lv_adj = 0.
          ELSE.
            lv_adj = lv_adj - <fs_final>-od181. <fs_final>-od181 = 0.
          ENDIF.
        ENDIF.
*       2) 121-180 Days
        IF lv_adj > 0 AND <fs_final>-od121 > 0.
          IF <fs_final>-od121 >= lv_adj.
            <fs_final>-od121 = <fs_final>-od121 - lv_adj. lv_adj = 0.
          ELSE.
            lv_adj = lv_adj - <fs_final>-od121. <fs_final>-od121 = 0.
          ENDIF.
        ENDIF.
*       3) 91-120 Days
        IF lv_adj > 0 AND <fs_final>-od91 > 0.
          IF <fs_final>-od91 >= lv_adj.
            <fs_final>-od91 = <fs_final>-od91 - lv_adj. lv_adj = 0.
          ELSE.
            lv_adj = lv_adj - <fs_final>-od91. <fs_final>-od91 = 0.
          ENDIF.
        ENDIF.
*       4) 61-90 Days
        IF lv_adj > 0 AND <fs_final>-od61 > 0.
          IF <fs_final>-od61 >= lv_adj.
            <fs_final>-od61 = <fs_final>-od61 - lv_adj. lv_adj = 0.
          ELSE.
            lv_adj = lv_adj - <fs_final>-od61. <fs_final>-od61 = 0.
          ENDIF.
        ENDIF.
*       5) 31-60 Days
        IF lv_adj > 0 AND <fs_final>-od31 > 0.
          IF <fs_final>-od31 >= lv_adj.
            <fs_final>-od31 = <fs_final>-od31 - lv_adj. lv_adj = 0.
          ELSE.
            lv_adj = lv_adj - <fs_final>-od31. <fs_final>-od31 = 0.
          ENDIF.
        ENDIF.
*       6) 0-30 Days
        IF lv_adj > 0 AND <fs_final>-od1 > 0.
          IF <fs_final>-od1 >= lv_adj.
            <fs_final>-od1 = <fs_final>-od1 - lv_adj. lv_adj = 0.
          ELSE.
            lv_adj = lv_adj - <fs_final>-od1. <fs_final>-od1 = 0.
          ENDIF.
        ENDIF.
*       7) Last resort: reduce Not Due
        IF lv_adj > 0 AND <fs_final>-notdue > 0.
          IF <fs_final>-notdue >= lv_adj.
            <fs_final>-notdue = <fs_final>-notdue - lv_adj. lv_adj = 0.
          ELSE.
            lv_adj = lv_adj - <fs_final>-notdue. <fs_final>-notdue = 0.
          ENDIF.
        ENDIF.

        <fs_final>-advance = 0.
      ENDIF.
    ENDIF.

*--- ZDOM and other groups: Total Due adjustment ---
    IF <fs_final>-ktokd NE 'ZEXP'.
      IF <fs_final>-total_due = 0 AND <fs_final>-notdue <> 0.
        <fs_final>-total_due = <fs_final>-notdue.
      ENDIF.
    ENDIF.

*--- Recalculate totals ---
    <fs_final>-total_due = <fs_final>-od1   + <fs_final>-od31  + <fs_final>-od61
                         + <fs_final>-od91  + <fs_final>-od121 + <fs_final>-od181.
    <fs_final>-total     = <fs_final>-total_due + <fs_final>-notdue.

  ENDLOOP.

ENDFORM.


*&---------------------------------------------------------------------*
*&      Form  FETCH_CREDIT_DATA_BATCH
*&---------------------------------------------------------------------*
* PERF: Single batched UKM_MALUSLIST_PROCESSING for ALL partners
*----------------------------------------------------------------------*
FORM fetch_credit_data_batch.

  TYPES: BEGIN OF ukmms_maluslist_dsp,
           t_partner_range   TYPE bup_partner_range_t,
           t_limitr_range    TYPE ukm_t_limit_rule_ranges,
           t_csgmnt_range    TYPE ukm_t_crsgm_range,
           t_follow_up_dt    TYPE RANGE OF ukm_follow_up_dt,
           t_credit_group    TYPE RANGE OF ukm_cred_group,
           t_coordinator     TYPE RANGE OF ukm_coordinator,
           t_risk_class      TYPE RANGE OF ukm_risk_class,
           t_ukmsb0_range    TYPE bup_partner_range_t,
           t_ukmsbg_range    TYPE bup_partner_range_t,
           t_where           TYPE rsds_twhere,
           t_range           TYPE rsds_trange,
           packsize          TYPE sy-tabix,
           t_out             TYPE ukm_t_bp_cms_malusdsp_out,
           credit_limit_used TYPE ukm_credlimit_used,
           log_handle        TYPE ukmms_tobj_handle,
           intnumber         TYPE sy-index,
           extnumber         TYPE balnrext,
           s_statistics      TYPE ukmms_massdata_statistics,
         END OF ukmms_maluslist_dsp,

         BEGIN OF ty_ntamt,
           kunnr    TYPE kunag,
           bukrs_vf TYPE bukrs_vf,
           netwr    TYPE netwr_ap,
         END OF ty_ntamt.

  DATA: lt_ukmms_parameters TYPE ukmms_maluslist_dsp,
        lr_partner_all      TYPE TABLE OF selopt,
        ls_partner_rng      TYPE selopt,
        lt_overdue          TYPE ukm_ts_bp_vector_it,
        lv_buspartnr        TYPE bu_partner,
        lv_segment          TYPE ukm_credit_sgmnt,
        lt_ntamt            TYPE TABLE OF ty_ntamt,
        ls_ntamt            TYPE ty_ntamt.

  FIELD-SYMBOLS: <fs_final>    TYPE ty_final,
                 <fs_partner>  TYPE ty_partner,
                 <fs_customer> TYPE ty_customer,
                 <fs_overdue>  TYPE LINE OF ukm_ts_bp_vector_it.

  CHECK gt_final IS NOT INITIAL.

  PERFORM get_partner_data USING gt_final[] gt_bsid
                        CHANGING gt_partner[] gt_customer[] gt_opensales[].

  SORT gt_partner  BY customer.
  SORT gt_customer BY customer.

* Build ONE range of ALL partners for single batch UKM call
  LOOP AT gt_partner ASSIGNING <fs_partner>.
    ls_partner_rng-sign   = 'I'.
    ls_partner_rng-option = 'EQ'.
    ls_partner_rng-low    = <fs_partner>-businesspartner.
    APPEND ls_partner_rng TO lr_partner_all.
  ENDLOOP.

  lv_segment = s_bukrs-low.

  IF lr_partner_all IS NOT INITIAL.
    lt_ukmms_parameters-t_partner_range[] = lr_partner_all.
    lt_ukmms_parameters-t_csgmnt_range[]  = s_bukrs[].

    CALL FUNCTION 'UKM_MALUSLIST_PROCESSING'
      CHANGING
        c_basics = lt_ukmms_parameters.
  ENDIF.

* Pre-calculate open order totals in single pass
  SORT gt_opensales BY kunnr.
  LOOP AT gt_opensales INTO DATA(ls_opensales).
    AT NEW kunnr.
      CLEAR ls_ntamt.
    ENDAT.
    ls_ntamt-netwr    = ls_ntamt-netwr + ls_opensales-netwr.
    ls_ntamt-bukrs_vf = ls_opensales-bukrs_vf.
    AT END OF kunnr.
      ls_ntamt-kunnr = ls_opensales-kunnr.
      APPEND ls_ntamt TO lt_ntamt.
    ENDAT.
  ENDLOOP.
  SORT lt_ntamt BY kunnr bukrs_vf.

* Fill credit data from batched results
  LOOP AT gt_final ASSIGNING <fs_final>.

    READ TABLE gt_partner ASSIGNING <fs_partner>
      WITH KEY customer = <fs_final>-kunnr BINARY SEARCH.
    IF sy-subrc = 0.
      lv_buspartnr = <fs_partner>-businesspartner.

      DATA(ls_ukmms) = VALUE #(
        lt_ukmms_parameters-t_out[ partner      = lv_buspartnr
                                    credit_sgmnt = lv_segment ] OPTIONAL ).
      IF ls_ukmms IS NOT INITIAL.
        <fs_final>-utilization    = ls_ukmms-credit_limit_used.
        <fs_final>-limit          = ls_ukmms-credit_limit.
        <fs_final>-exposure       = ls_ukmms-amount.
        <fs_final>-total_exposure = ls_ukmms-credit_limit_usedw.
      ENDIF.

      CLEAR lt_overdue.
      CALL FUNCTION 'UKM_DB_UKMBP_VECTOR_READ'
        EXPORTING
          i_partner       = lv_buspartnr
          i_segment       = lv_segment
        IMPORTING
          et_bp_vector_it = lt_overdue
        EXCEPTIONS
          not_found = 1
          OTHERS    = 2.
      IF sy-subrc = 0.
        READ TABLE lt_overdue ASSIGNING <fs_overdue> INDEX 1.
        IF sy-subrc = 0.
          <fs_final>-ovdue_days     = <fs_overdue>-ovdue_days.
          <fs_final>-ovdue_amount   = <fs_overdue>-ovdue_amount.
          <fs_final>-ovdue_net_date = <fs_overdue>-ovdue_net_date.
          <fs_final>-paymnt_amount  = <fs_overdue>-paymnt_amount.
          <fs_final>-paymnt_date    = <fs_overdue>-paymnt_date.
        ENDIF.
      ENDIF.
    ENDIF.

    READ TABLE gt_customer ASSIGNING <fs_customer>
      WITH KEY customer = <fs_final>-kunnr BINARY SEARCH.
    IF sy-subrc = 0.
      <fs_final>-customer_group     = <fs_customer>-customer_group.
      <fs_final>-custom_group_descp = <fs_customer>-custom_group_descp.
      <fs_final>-sales_group        = <fs_customer>-sales_group.
      <fs_final>-sales_group_descp  = <fs_customer>-sales_group_descp.
    ENDIF.

    READ TABLE lt_ntamt INTO ls_ntamt
      WITH KEY kunnr    = <fs_final>-kunnr
               bukrs_vf = s_bukrs-low
      BINARY SEARCH.
    IF sy-subrc = 0.
      <fs_final>-open_order_value = ls_ntamt-netwr.
    ENDIF.

  ENDLOOP.

ENDFORM.


*&---------------------------------------------------------------------*
*&      Form  GET_PARTNER_DATA
*&---------------------------------------------------------------------*
FORM get_partner_data USING pt_data LIKE gt_final
                            pt_comp LIKE gt_bsid
                   CHANGING ct_partner LIKE gt_partner
                            ct_customer LIKE gt_customer
                            ct_opensales LIKE gt_opensales.

  DATA: lr_kunnr TYPE TABLE OF selopt.

  CLEAR: ct_partner, ct_customer, ct_opensales.
  CHECK pt_data IS NOT INITIAL.

  DATA(lt_data) = pt_data[].
  SORT lt_data BY kunnr.
  DELETE ADJACENT DUPLICATES FROM lt_data COMPARING kunnr.

  lr_kunnr = VALUE #( FOR ls_kunnr IN lt_data
                      ( sign = 'I' option = 'EQ' low = ls_kunnr-kunnr ) ).

  CHECK lr_kunnr IS NOT INITIAL.

  SELECT customer, businesspartner
  FROM abusinesspartner
  INTO TABLE @ct_partner
  WHERE customer IN @lr_kunnr.

  IF ct_partner IS NOT INITIAL.
    SELECT a~kunnr, a~kdgrp, b~ktext, a~vkgrp, c~bezei
    FROM knvv AS a
    INNER JOIN t151t AS b ON a~kdgrp = b~kdgrp
    INNER JOIN tvgrt AS c ON a~vkgrp = c~vkgrp
    INTO TABLE @ct_customer
    FOR ALL ENTRIES IN @ct_partner
    WHERE kunnr = @ct_partner-customer
    AND   c~spras = @sy-langu.
  ENDIF.

  SELECT a~vbeln, a~kunnr, a~bukrs_vf, b~gbsta, b~netwr,
         a~gbstk, a~lfgsk, b~lfgsa
  FROM vbak AS a
  INNER JOIN vbap AS b ON a~vbeln = b~vbeln
  INTO CORRESPONDING FIELDS OF TABLE @ct_opensales
  WHERE a~kunnr IN @lr_kunnr
  AND   a~bukrs_vf IN @s_bukrs
  AND   b~gbsta <> 'C'
  AND ( ( a~gbstk EQ 'A' OR a~gbstk = 'B' )
     OR ( a~lfgsk EQ 'A' OR a~lfgsk = 'B' ) )
  AND ( ( b~gbsta = 'A' OR b~gbsta = 'B' )
     OR ( b~lfgsa = 'A' OR b~lfgsa = 'B' ) ).

ENDFORM.


