*&---------------------------------------------------------------------*
*&      Form  GEN_TOP
*&---------------------------------------------------------------------*
FORM gen_top .

  DATA: info(100), lv_text TYPE string,
        lv_butxt TYPE char25, ls_line TYPE slis_listheader.

  ls_line-typ = 'H'.
  SELECT SINGLE butxt INTO lv_butxt FROM t001 WHERE bukrs = s_bukrs-low.
  ls_line-info = lv_butxt.
  APPEND ls_line TO gt_top_of_page.

  CLEAR ls_line.
  ls_line-typ = 'H'. ls_line-info = 'ECGC Customer Ageing Report (Due Date)'.
  APPEND ls_line TO gt_top_of_page.

  CLEAR: ls_line, info. ls_line-typ = 'S'.
  IF s_rbusa-low IS NOT INITIAL.
    WRITE s_rbusa-low TO info.
    SELECT SINGLE gtext FROM tgsbt INTO lv_text WHERE gsber = s_rbusa-low.
    CONDENSE lv_text.
  ELSEIF s_rbusa-high IS NOT INITIAL.
    WRITE s_rbusa-high TO info.
    SELECT SINGLE gtext FROM tgsbt INTO lv_text WHERE gsber = s_rbusa-high.
    CONDENSE lv_text.
  ELSE.
    WRITE '*' TO info.
  ENDIF.
  CONDENSE info.
  CONCATENATE 'Business Area :' info lv_text INTO info SEPARATED BY space.
  ls_line-info = info. APPEND ls_line TO gt_top_of_page.

  CLEAR: ls_line, info. ls_line-typ = 'S'.
  WRITE p_date TO info. CONDENSE info.
  CONCATENATE 'Key Date :' info INTO info SEPARATED BY space.
  ls_line-info = info. APPEND ls_line TO gt_top_of_page.

  CLEAR ls_line. ls_line-typ = 'S'.
  WRITE sy-datum TO info.
  CONCATENATE 'Date :' info INTO info SEPARATED BY space.
  ls_line-info = info. APPEND ls_line TO gt_top_of_page.

  CLEAR ls_line. ls_line-typ = 'S'.
  ls_line-info = 'Ageing: Due Date | Groups: ZEXP, ZDOM (Entities Eliminated)'.
  APPEND ls_line TO gt_top_of_page.

ENDFORM.


