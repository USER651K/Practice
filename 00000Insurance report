  add_fldcat 'NAME1' 'Customer Name'.
  add_fldcat 'VKORG' 'Customer Classification'.
  add_fldcat 'KTOKD' 'Customer Account Group'.
  add_fldcat 'KTOKD_D' 'Customer Account Desc'.
  add_fldcat 'REGIO' 'Customer Region'.
  add_fldcat 'REGIO_D' 'Customer Region Desc'.
  add_fldcat 'PARVW' 'Partner Function'.
  add_fldcat 'PERNR' 'Sales Employee Number'.
  add_fldcat 'NAME'  'Sales Employee'.
  add_fldcat 'TELNR' 'Telephone'.

  IF rb_dtl = 'X'.
    add_fldcat 'DOCNR' 'Document Number'.
    add_fldcat 'BLART' 'Doc Type'.
    add_fldcat 'EBELN' 'PO No'.
    add_fldcat 'XBLNR' 'Reference'.
    add_fldcat 'BLDAT' 'Document Date'.
    add_fldcat 'BUDAT' 'Posting Date'.
    add_fldcat 'UMSKZ' 'Spcl. G/L Ind.'.
    add_fldcat 'DUDAT' 'Due Date'.
    add_fldcat 'DAYNO' 'No Of Days'.
    add_fldcat 'AMT_DBT' 'Debit Amount'.
    add_fldcat 'AMT_CDT' 'Credit Amount'.
    add_fldcat 'ADVANCE' 'Advance'.
    add_fldcat 'NETVAL'  'Net Value'.
    add_fldcat 'HKONT'  'G/L Account'.
