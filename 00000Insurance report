FORM create_fldcat .

  DATA : lv_fldcat  TYPE slis_fieldcat_alv,
         lv_index   TYPE i,
         lv_from(4).

  CONCATENATE '0 -' p_c1 'Days' INTO c1 SEPARATED BY space.
  lv_from = p_c1 + 1. CONCATENATE lv_from '-' p_c2 'Days' INTO c2 SEPARATED BY space.
  lv_from = p_c2 + 1. CONCATENATE lv_from '-' p_c3 'Days' INTO c3 SEPARATED BY space.
  lv_from = p_c3 + 1. CONCATENATE lv_from '-' p_c4 'Days' INTO c4 SEPARATED BY space.
  lv_from = p_c4 + 1. CONCATENATE lv_from '-' p_c5 'Days' INTO c5 SEPARATED BY space.
  lv_from = p_c5 + 1. CONCATENATE '>' lv_from 'Days' INTO c7 SEPARATED BY space.

  IF rb_dtl = 'X'.
    gv_tabname = 'GT_FINAL_DTL'.
  ELSEIF rb_sum = 'X'.
