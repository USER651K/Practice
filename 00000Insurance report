  add_fldcat 'NOTDUE' 'Not Due'.
  add_fldcat 'OD1'    c1.
  add_fldcat 'OD31'   c2.
  add_fldcat 'OD61'   c3.
  add_fldcat 'OD91'   c4.
  add_fldcat 'OD121'  c5.
  add_fldcat 'OD181'  c7.

  IF rb_sum = 'X'.
