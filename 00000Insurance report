*&---------------------------------------------------------------------*
*&      Form  ELIMINATE_GROUP_ENTITIES
*&---------------------------------------------------------------------*
FORM eliminate_group_entities.

  DATA: lv_name_upper TYPE char40,
        lv_delete     TYPE abap_bool.

  FIELD-SYMBOLS: <fs_kna1r> TYPE ty_kna1_r,
                 <fs_elim>  TYPE ty_elim_entity.

  LOOP AT it_kna1_r ASSIGNING <fs_kna1r>.
    lv_delete = abap_false.
    lv_name_upper = <fs_kna1r>-name1.
    TRANSLATE lv_name_upper TO UPPER CASE.

    LOOP AT gt_elim_entities ASSIGNING <fs_elim>.
      IF lv_name_upper CS <fs_elim>-name.
        lv_delete = abap_true.
        EXIT.
      ENDIF.
    ENDLOOP.

    IF lv_delete = abap_true.
      DELETE it_kna1_r.
    ENDIF.
  ENDLOOP.

  REFRESH t_kunnr_r.
  LOOP AT it_kna1_r ASSIGNING <fs_kna1r>.
    w_kunnr_r-sign   = 'I'.
    w_kunnr_r-option = 'EQ'.
    w_kunnr_r-low    = <fs_kna1r>-kunnr.
    APPEND w_kunnr_r TO t_kunnr_r.
  ENDLOOP.

  IF t_kunnr_r IS INITIAL.
    MESSAGE 'No customers remain after group entity elimination' TYPE 'I' DISPLAY LIKE 'E'.
    LEAVE LIST-PROCESSING.
  ENDIF.

ENDFORM.


*&---------------------------------------------------------------------*
*&      Form  FETCH_BSAD
*&---------------------------------------------------------------------*
* NET_DUE_DATE_GET retained for correctness (handles rebzg, shkzg, koart)
* FIMA_DAYS_AND_MONTHS_AND_YEARS replaced with safe ABAP date subtraction
*----------------------------------------------------------------------*
FORM fetch_bsad .

  DATA: lv_date1 TYPE datum,
        lv_diff  TYPE i.

  FIELD-SYMBOLS: <fs_bsad> TYPE ty_bsad,
                 <fs_fagl> TYPE ty_fagl,
                 <fs_t074> TYPE ts_t074.

  IF s_hkont IS NOT INITIAL.
    SELECT umskz hkont skont
    FROM t074 INTO TABLE it_t074
    WHERE ktopl EQ '5000'
    AND   umskz IN s_glind
    AND   hkont IN s_hkont.

    IF sy-subrc EQ 0.
      LOOP AT s_hkont.
        w_hkont-sign = 'I'. w_hkont-option = 'EQ'. w_hkont-low = s_hkont-low.
        APPEND w_hkont TO t_hkont. CLEAR w_hkont.
      ENDLOOP.
      LOOP AT it_t074 ASSIGNING <fs_t074>.
        w_hkont-sign = 'I'. w_hkont-option = 'EQ'. w_hkont-low = <fs_t074>-skont.
        APPEND w_hkont TO t_hkont. CLEAR w_hkont.
      ENDLOOP.
      SORT t_hkont BY low.
      DELETE ADJACENT DUPLICATES FROM t_hkont COMPARING low.
      DELETE t_hkont WHERE low IS INITIAL.

      SELECT bukrs kunnr umskz augdt gjahr belnr buzei budat
             bldat xblnr blart bschl gsber dmbtr hkont
             zfbdt zterm zbd1t zbd2t zbd3t rebzg rebzj rebzz shkzg
      FROM bsad INTO CORRESPONDING FIELDS OF TABLE gt_bsad
      WHERE bukrs EQ s_bukrs-low
      AND   kunnr IN t_kunnr_r
      AND   umskz IN s_glind
      AND   augdt GT p_date
      AND   budat LE p_date
      AND   blart IN s_blart
      AND   hkont IN t_hkont.
    ENDIF.
  ELSE.
    SELECT bukrs kunnr umskz augdt gjahr belnr buzei budat
           bldat xblnr blart bschl gsber dmbtr hkont
           zfbdt zterm zbd1t zbd2t zbd3t rebzg rebzj rebzz shkzg
    FROM bsad INTO CORRESPONDING FIELDS OF TABLE gt_bsad
    WHERE bukrs EQ s_bukrs-low
    AND   kunnr IN t_kunnr_r
    AND   umskz IN s_glind
    AND   augdt GT p_date
    AND   budat LE p_date
    AND   blart IN s_blart
    AND   hkont IN s_hkont.
  ENDIF.

  CHECK gt_bsad IS NOT INITIAL.

  SELECT ryear docnr rbukrs docln prctr rbusa hsl drcrk buzei bschl
  FROM faglflexa INTO TABLE gt_fagl_bsad
  FOR ALL ENTRIES IN gt_bsad
  WHERE rbukrs EQ gt_bsad-bukrs
  AND   ryear  EQ gt_bsad-gjahr
  AND   docnr  EQ gt_bsad-belnr
  AND   buzei  EQ gt_bsad-buzei
  AND   rldnr  EQ '0L'
  AND   rbusa  IN s_rbusa
  AND   prctr  IN s_prctr.

* Sort for BINARY SEARCH
  SORT gt_bsad BY bukrs gjahr belnr buzei.

* Backfill bschl from BSAD into FAGL where missing
  LOOP AT gt_fagl_bsad ASSIGNING <fs_fagl> WHERE bschl IS INITIAL.
    READ TABLE gt_bsad ASSIGNING <fs_bsad>
      WITH KEY bukrs = <fs_fagl>-rbukrs
               gjahr = <fs_fagl>-ryear
               belnr = <fs_fagl>-docnr
               buzei = <fs_fagl>-buzei
      BINARY SEARCH.
    IF sy-subrc = 0.
      <fs_fagl>-bschl = <fs_bsad>-bschl.
    ENDIF.
  ENDLOOP.

* Due date calculation and day difference
  LOOP AT gt_bsad ASSIGNING <fs_bsad>.
    CLEAR lv_date1.

*   NET_DUE_DATE_GET retained: handles rebzg, shkzg, koart correctly
    CALL FUNCTION 'NET_DUE_DATE_GET'
      EXPORTING
        i_zfbdt = <fs_bsad>-zfbdt
        i_zbd1t = <fs_bsad>-zbd1t
        i_zbd2t = <fs_bsad>-zbd2t
        i_zbd3t = <fs_bsad>-zbd3t
        i_shkzg = <fs_bsad>-shkzg
        i_rebzg = <fs_bsad>-rebzg
        i_koart = 'D'
      IMPORTING
        e_faedt = lv_date1.

    <fs_bsad>-duedt = lv_date1.

*   PERF: Replaces FIMA_DAYS_AND_MONTHS_AND_YEARS with ABAP date math
*   (safe: only day difference needed, ABAP date subtraction = identical result)
    IF lv_date1 > p_date.
      <fs_bsad>-no_days = lv_date1 - p_date.
    ELSE.
      lv_diff = p_date - lv_date1.
      <fs_bsad>-no_days = lv_diff * -1.
    ENDIF.
  ENDLOOP.

ENDFORM.


*&---------------------------------------------------------------------*
*&      Form  FETCH_BSID
*&---------------------------------------------------------------------*
FORM fetch_bsid .

  DATA: lv_date1 TYPE datum,
        lv_diff  TYPE i.

  FIELD-SYMBOLS: <fs_bsid> TYPE ty_bsad,
                 <fs_fagl> TYPE ty_fagl,
                 <fs_t074> TYPE ts_t074.

  REFRESH it_t074.

  IF s_hkont IS NOT INITIAL.
    SELECT umskz hkont skont
    FROM t074 INTO TABLE it_t074
    WHERE ktopl EQ '5000'
    AND   umskz IN s_glind
    AND   hkont IN s_hkont.

    IF sy-subrc EQ 0.
      LOOP AT s_hkont.
        w_hkont-sign = 'I'. w_hkont-option = 'EQ'. w_hkont-low = s_hkont-low.
        APPEND w_hkont TO t_hkont. CLEAR w_hkont.
      ENDLOOP.
      LOOP AT it_t074 ASSIGNING <fs_t074>.
        w_hkont-sign = 'I'. w_hkont-option = 'EQ'. w_hkont-low = <fs_t074>-skont.
        APPEND w_hkont TO t_hkont. CLEAR w_hkont.
      ENDLOOP.
      SORT t_hkont BY low.
      DELETE ADJACENT DUPLICATES FROM t_hkont COMPARING low.
      DELETE t_hkont WHERE low IS INITIAL.

      SELECT bukrs kunnr umskz augdt gjahr belnr buzei budat
             bldat xblnr blart bschl gsber dmbtr hkont
             zfbdt zterm zbd1t zbd2t zbd3t rebzg rebzj rebzz shkzg
      FROM bsid INTO CORRESPONDING FIELDS OF TABLE gt_bsid
      WHERE bukrs EQ s_bukrs-low
      AND   kunnr IN t_kunnr_r
      AND   umskz IN s_glind
      AND   budat LE p_date
      AND   blart IN s_blart
      AND   hkont IN t_hkont.
    ENDIF.
  ELSE.
    SELECT bukrs kunnr umskz augdt gjahr belnr buzei budat
           bldat xblnr blart bschl gsber dmbtr hkont
           zfbdt zterm zbd1t zbd2t zbd3t rebzg rebzj rebzz shkzg
    FROM bsid INTO CORRESPONDING FIELDS OF TABLE gt_bsid
    WHERE bukrs EQ s_bukrs-low
    AND   kunnr IN t_kunnr_r
    AND   umskz IN s_glind
    AND   budat LE p_date
    AND   blart IN s_blart
    AND   hkont IN s_hkont.
  ENDIF.

  CHECK gt_bsid IS NOT INITIAL.

  SELECT ryear docnr rbukrs docln prctr rbusa hsl drcrk buzei bschl
  FROM faglflexa INTO TABLE gt_fagl_bsid
  FOR ALL ENTRIES IN gt_bsid
  WHERE rbukrs EQ gt_bsid-bukrs
  AND   ryear  EQ gt_bsid-gjahr
  AND   docnr  EQ gt_bsid-belnr
  AND   buzei  EQ gt_bsid-buzei
  AND   rldnr  EQ '0L'
  AND   rbusa  IN s_rbusa
  AND   prctr  IN s_prctr.

  SORT gt_bsid BY bukrs gjahr belnr buzei.

  LOOP AT gt_fagl_bsid ASSIGNING <fs_fagl> WHERE bschl IS INITIAL.
    READ TABLE gt_bsid ASSIGNING <fs_bsid>
      WITH KEY bukrs = <fs_fagl>-rbukrs
               gjahr = <fs_fagl>-ryear
               belnr = <fs_fagl>-docnr
               buzei = <fs_fagl>-buzei
      BINARY SEARCH.
    IF sy-subrc = 0.
      <fs_fagl>-bschl = <fs_bsid>-bschl.
    ENDIF.
  ENDLOOP.

  LOOP AT gt_bsid ASSIGNING <fs_bsid>.
    CLEAR lv_date1.

    CALL FUNCTION 'NET_DUE_DATE_GET'
      EXPORTING
        i_zfbdt = <fs_bsid>-zfbdt
        i_zbd1t = <fs_bsid>-zbd1t
        i_zbd2t = <fs_bsid>-zbd2t
        i_zbd3t = <fs_bsid>-zbd3t
        i_shkzg = <fs_bsid>-shkzg
        i_rebzg = <fs_bsid>-rebzg
        i_koart = 'D'
      IMPORTING
        e_faedt = lv_date1.

    <fs_bsid>-duedt = lv_date1.

    IF lv_date1 > p_date.
      <fs_bsid>-no_days = lv_date1 - p_date.
    ELSE.
      lv_diff = p_date - lv_date1.
      <fs_bsid>-no_days = lv_diff * -1.
    ENDIF.
  ENDLOOP.

ENDFORM.


*&---------------------------------------------------------------------*
