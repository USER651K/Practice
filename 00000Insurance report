*&---------------------------------------------------------------------*
*&      Form  FETCH_KNA1
*&---------------------------------------------------------------------*
FORM fetch_kna1 .

  FIELD-SYMBOLS: <fs_kna1r> TYPE ty_kna1_r.

  REFRESH: it_kna1_r, t_kunnr_r, it_t077x, it_knvp.

  SELECT a~kunnr a~name1 a~ort01 a~ktokd a~regio
         b~parvw b~pernr
  FROM kna1 AS a
  LEFT OUTER JOIN knvp AS b
    ON a~kunnr = b~kunnr AND b~parvw = 'VE'
  INTO TABLE it_kna1_r
  WHERE a~kunnr IN s_kunnr
  AND   a~ktokd IN s_ktokd
  AND   a~regio IN s_regio.

  DELETE it_kna1_r WHERE pernr NOT IN s_pernr.

  IF it_kna1_r IS INITIAL.
    MESSAGE 'No Data is available as per Selection' TYPE 'I' DISPLAY LIKE 'E'.
    LEAVE LIST-PROCESSING.
  ENDIF.

  LOOP AT it_kna1_r ASSIGNING <fs_kna1r>.
    w_kunnr_r-sign = 'I'. w_kunnr_r-option = 'EQ'. w_kunnr_r-low = <fs_kna1r>-kunnr.
    APPEND w_kunnr_r TO t_kunnr_r.
  ENDLOOP.

  IF it_kna1_r IS NOT INITIAL.
    SELECT pernr ename FROM pa0001 INTO TABLE it_pa0001
      FOR ALL ENTRIES IN it_kna1_r WHERE pernr = it_kna1_r-pernr.

    SELECT pernr telnr FROM pa0006 INTO TABLE it_pa0006
      FOR ALL ENTRIES IN it_kna1_r WHERE pernr = it_kna1_r-pernr.

    SELECT * FROM t077x INTO TABLE it_t077x
      FOR ALL ENTRIES IN it_kna1_r
      WHERE spras = sy-langu AND ktokd = it_kna1_r-ktokd.

    SELECT * FROM t005u INTO TABLE it_t005u
      FOR ALL ENTRIES IN it_kna1_r
      WHERE spras = sy-langu AND land1 = 'IN' AND bland = it_kna1_r-regio.
  ENDIF.

  DELETE it_t077x WHERE spras <> sy-langu.
  DELETE it_t005u WHERE spras <> sy-langu OR land1 <> 'IN'.

ENDFORM.

